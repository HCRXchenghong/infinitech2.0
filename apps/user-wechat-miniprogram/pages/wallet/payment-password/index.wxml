<view class="page">
  <view class="panel">
    <text class="title">设置余额支付密码</text>
    <text class="subtitle">余额支付前必须设置 6 位数字密码。后续会增加错误次数锁定和找回流程。</text>
    <input class="input" password maxlength="6" type="number" placeholder="输入 6 位数字" value="{{password}}" bindinput="handlePasswordInput" />
    <input class="input" password maxlength="6" type="number" placeholder="再次输入" value="{{confirmPassword}}" bindinput="handleConfirmInput" />
    <button class="submit-button" bindtap="handleSubmitTap">保存</button>
  </view>
</view>
