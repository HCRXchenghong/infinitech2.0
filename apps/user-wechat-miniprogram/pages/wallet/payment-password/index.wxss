.page {
  min-height: 100vh;
  padding: 44rpx 28rpx;
  box-sizing: border-box;
  background: #f3f4f6;
}

.safe-icon {
  width: 112rpx;
  height: 112rpx;
  margin: 26rpx auto 28rpx;
  border-radius: 56rpx;
  background: #e0f2fe;
  color: #009bf5;
  text-align: center;
  line-height: 112rpx;
  font-size: 38rpx;
  font-weight: 900;
}

.panel {
  padding: 28rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 16rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.title {
  display: block;
  color: #111827;
  font-size: 34rpx;
  font-weight: 800;
}

.subtitle {
  display: block;
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.5;
}

.field-title {
  display: block;
  margin-top: 34rpx;
  color: #111827;
  font-size: 28rpx;
  font-weight: 800;
}

.dot-row {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 12rpx;
  margin-top: 22rpx;
}

.dot {
  height: 76rpx;
  border: 1rpx solid #dbeafe;
  border-radius: 14rpx;
  background: #f8fafc;
  position: relative;
}

.dot.active::after {
  content: "";
  width: 18rpx;
  height: 18rpx;
  border-radius: 9rpx;
  background: #111827;
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
}

.hidden-input {
  height: 2rpx;
  opacity: 0;
}

.hint {
  display: block;
  margin-top: 14rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.submit-button {
  margin-top: 28rpx;
  border-radius: 10rpx;
  color: #ffffff;
  background: #009bf5;
  font-size: 26rpx;
}

.tip-card {
  margin-top: 22rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.04);
}

.tip-card text {
  display: block;
  color: #4b5563;
  font-size: 24rpx;
  line-height: 1.8;
}

.links {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  margin-top: 32rpx;
  color: #009bf5;
  font-size: 24rpx;
}
