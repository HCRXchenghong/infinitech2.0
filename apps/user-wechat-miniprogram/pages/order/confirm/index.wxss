.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 148rpx;
  box-sizing: border-box;
  background: #f3f4f6;
}

.address-card,
.section {
  margin-bottom: 18rpx;
  padding: 24rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 16rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.section-label,
.address-contact,
.bottom-note {
  display: block;
  color: #6b7280;
  font-size: 24rpx;
}

.address-detail,
.section-title,
.payable {
  display: block;
  color: #111827;
  font-weight: 700;
}

.address-detail {
  margin-top: 10rpx;
  font-size: 34rpx;
}

.address-contact {
  margin-top: 8rpx;
}

.section-title {
  margin-bottom: 12rpx;
  font-size: 30rpx;
}

.order-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 10rpx 0;
  color: #374151;
  font-size: 26rpx;
}

.order-row navigator {
  color: #009bf5;
}

.bottom-bar {
  position: fixed;
  right: 28rpx;
  bottom: 32rpx;
  left: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  background: #111827;
  box-sizing: border-box;
}

.payable {
  color: #ffffff;
  font-size: 34rpx;
}

.bottom-note {
  margin-top: 4rpx;
  color: #d1d5db;
}

.pay-button {
  min-width: 196rpx;
  border-radius: 10rpx;
  color: #ffffff;
  background: #009bf5;
  font-size: 26rpx;
}
