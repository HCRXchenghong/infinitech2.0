.summary-card {
  margin-bottom: 12px;
  padding: 16px;
  border-radius: 12px;
  background: #ffffff;
  box-shadow: 0 6px 18px rgba(15, 23, 42, 0.05);
}

.summary-head,
.rating-row,
.review-tools,
.dish-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.section-head,
.dish-title-row,
.star-group,
.dish-star-group {
  display: flex;
  align-items: center;
}

.section-head {
  justify-content: space-between;
  gap: 12px;
}

.section-note {
  flex-shrink: 0;
  color: #94a3b8;
  font-size: 11px;
  font-weight: 600;
}

.summary-shop {
  color: #111827;
  font-size: 17px;
  font-weight: 900;
}

.summary-status,
.summary-paid {
  color: #009bf5;
  font-size: 13px;
  font-weight: 800;
}

.summary-line {
  display: block;
  margin-top: 7px;
  color: #6b7280;
  font-size: 13px;
}

.summary-paid {
  display: block;
  margin-top: 10px;
  font-size: 18px;
}

.rating-row {
  padding: 10px 0;
  border-bottom: 1px solid #eef2f7;
}

.stars {
  color: #f59e0b;
  font-size: 18px;
  white-space: nowrap;
}

.star-group {
  gap: 2px;
}

.star {
  color: #cbd5e1;
  font-size: 20px;
  line-height: 1;
}

.star.active {
  color: #f59e0b;
}

.tag-list,
.dish-tags,
.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 12px;
}

.tag,
.dish-tags text {
  min-height: 25px;
  border-radius: 13px;
  padding: 0 10px;
  background: #f8fafc;
  color: #64748b;
  line-height: 25px;
  font-size: 12px;
  font-weight: 700;
}

.tag.active {
  background: #e0f2fe;
  color: #009bf5;
}

.review-tools {
  margin-top: 10px;
  color: #6b7280;
  font-size: 12px;
}

.review-tools label {
  display: flex;
  align-items: center;
  gap: 6px;
}

.dish-row {
  justify-content: flex-start;
  padding: 12px 0;
  border-bottom: 1px solid #eef2f7;
}

.dish-row:last-child {
  border-bottom: none;
}

.dish-thumb {
  width: 54px;
  height: 54px;
  border-radius: 12px;
  background: linear-gradient(135deg, #dbeafe, #f8fafc);
  color: #009bf5;
  text-align: center;
  line-height: 54px;
  font-size: 17px;
  font-weight: 900;
}

.dish-main {
  flex: 1;
  min-width: 0;
}

.dish-title-row {
  justify-content: space-between;
  gap: 12px;
}

.dish-title {
  color: #111827;
  font-size: 15px;
  font-weight: 800;
}

.dish-quantity {
  flex-shrink: 0;
  color: #94a3b8;
  font-size: 12px;
  font-weight: 700;
}

.dish-tags {
  margin-top: 6px;
}

.dish-star-group {
  gap: 2px;
  margin-top: 4px;
}

.star.small {
  font-size: 17px;
}

.image-slot {
  width: 78px;
  min-height: 78px;
  height: 78px;
  border: 1px dashed #cbd5e1;
  border-radius: 12px;
  background: #f8fafc;
  color: #94a3b8;
  font-size: 22px;
  font-weight: 700;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.image-slot.uploaded {
  border: none;
  background: linear-gradient(135deg, #dbeafe, #f8fafc);
  color: #009bf5;
  padding: 10px 8px;
  flex-direction: column;
  gap: 6px;
}

.image-slot.pending {
  border-color: #bae6fd;
  background: linear-gradient(135deg, #e0f2fe, #f8fafc);
  color: #0284c7;
  padding: 10px 8px;
  flex-direction: column;
  gap: 6px;
}

.image-slot.action {
  border-color: #7dd3fc;
  color: #009bf5;
}

.image-slot.empty {
  color: #cbd5e1;
}

.image-name,
.image-meta {
  display: block;
  line-height: 1.35;
}

.image-name {
  color: inherit;
  font-size: 12px;
  font-weight: 800;
  word-break: break-all;
}

.image-meta {
  color: #64748b;
  font-size: 10px;
  font-weight: 700;
}

.mp-bottom-inner .mp-button {
  flex: 1;
}
