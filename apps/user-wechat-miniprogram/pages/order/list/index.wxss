.page {
  min-height: 100vh;
  padding: 0 28rpx 44rpx;
  box-sizing: border-box;
  background:
    linear-gradient(180deg, #eaf5ff 0, #eef8ff 300rpx, #f7fbff 520rpx, #f5f7fb 100%);
  color: #111827;
}

.order-sticky {
  position: sticky;
  top: 0;
  z-index: 40;
  margin: 0 -28rpx;
  padding: 88rpx 28rpx 20rpx;
  background: linear-gradient(180deg, #eaf5ff 0, #eef8ff 100%);
  box-shadow: 0 10rpx 24rpx rgba(52, 83, 125, 0.05);
  box-sizing: border-box;
}

.order-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 64rpx;
}

.nav-title {
  display: block;
  width: 100%;
  color: #111827;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.25;
  text-align: center;
}

.search-bar {
  height: 88rpx;
  margin-top: 22rpx;
  padding: 0 30rpx;
  border: 2rpx solid rgba(205, 217, 230, 0.92);
  border-radius: 44rpx;
  background: rgba(255, 255, 255, 0.96);
  display: grid;
  grid-template-columns: 42rpx minmax(0, 1fr) 34rpx;
  align-items: center;
  gap: 18rpx;
  box-sizing: border-box;
  box-shadow: 0 12rpx 34rpx rgba(15, 23, 42, 0.05);
}

.search-icon,
.clear-icon {
  color: #9aa8ba;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1;
}

.clear-icon {
  font-size: 34rpx;
  text-align: right;
}

.search-input {
  min-width: 0;
  height: 86rpx;
  color: #111827;
  font-size: 30rpx;
  font-weight: 700;
}

.status-scroll {
  width: 100%;
  margin-top: 20rpx;
  white-space: nowrap;
}

.status-tabs {
  display: inline-flex;
  align-items: flex-end;
  gap: 36rpx;
  min-width: 100%;
  height: 64rpx;
}

.status-tab {
  position: relative;
  min-width: 96rpx;
  height: 62rpx;
  color: #7b8798;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 54rpx;
  text-align: center;
}

.status-tab.active {
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
}

.status-tab.active::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 42rpx;
  height: 8rpx;
  margin-left: -21rpx;
  border-radius: 999rpx;
  background: #159cff;
}

.empty-card {
  margin-top: 24rpx;
  padding: 56rpx 28rpx;
  border-radius: 28rpx;
  background: #ffffff;
  text-align: center;
  box-shadow: 0 14rpx 40rpx rgba(52, 83, 125, 0.08);
}

.empty-title,
.empty-copy {
  display: block;
}

.empty-title {
  color: #111827;
  font-size: 31rpx;
  font-weight: 900;
}

.empty-copy {
  margin-top: 12rpx;
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.5;
}

.order-card {
  margin-top: 22rpx;
  padding: 24rpx;
  border: 2rpx solid rgba(222, 235, 247, 0.75);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.98);
  box-sizing: border-box;
  box-shadow: 0 14rpx 40rpx rgba(52, 83, 125, 0.08);
}

.card-head,
.merchant,
.order-body,
.action-row {
  display: flex;
  align-items: center;
}

.card-head,
.order-body {
  justify-content: space-between;
  gap: 18rpx;
}

.merchant {
  min-width: 0;
  gap: 18rpx;
}

.merchant-image,
.merchant-fallback {
  width: 92rpx;
  height: 92rpx;
  border-radius: 24rpx;
  flex: 0 0 92rpx;
  overflow: hidden;
}

.merchant-fallback {
  color: #159cff;
  background: #eaf7ff;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 92rpx;
  text-align: center;
}

.merchant-copy,
.item-copy {
  min-width: 0;
}

.shop-name,
.order-time,
.subtitle,
.eta {
  display: block;
  min-width: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.shop-name {
  color: #111827;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 1.25;
}

.order-time {
  margin-top: 8rpx;
  color: #8a96a6;
  font-size: 23rpx;
  font-weight: 700;
}

.status-pill {
  flex-shrink: 0;
  min-width: 94rpx;
  height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 42rpx;
  text-align: center;
  box-sizing: border-box;
}

.status-pill.blue {
  color: #0b82df;
  background: #eaf7ff;
}

.status-pill.orange {
  color: #ff6a2a;
  background: #fff4ed;
}

.status-pill.red {
  color: #ef4444;
  background: #fff1f2;
}

.status-pill.gray {
  color: #64748b;
  background: #f1f5f9;
}

.order-body {
  margin-top: 26rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f8fbff;
}

.subtitle {
  color: #1f2937;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 1.3;
}

.eta {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 24rpx;
  font-weight: 700;
}

.amount {
  flex-shrink: 0;
  color: #111827;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1;
}

.action-row {
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 22rpx;
}

.action-button {
  min-width: 154rpx;
  height: 60rpx;
  margin: 0;
  padding: 0 22rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 60rpx;
  box-sizing: border-box;
}

.action-button::after {
  border: none;
}

.action-button.ghost {
  color: #516173;
  background: #f1f5f9;
}

.action-button.primary {
  color: #ffffff;
  background: #159cff;
  box-shadow: 0 10rpx 20rpx rgba(21, 156, 255, 0.2);
}

.action-button.primary.warm {
  background: #ff5a4f;
  box-shadow: 0 10rpx 20rpx rgba(255, 90, 79, 0.2);
}
