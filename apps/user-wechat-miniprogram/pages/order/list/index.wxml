<view class="page">
  <view class="order-sticky">
    <view class="order-nav">
      <text class="nav-title">我的订单</text>
    </view>

    <view class="search-bar">
      <text class="search-icon">⌕</text>
      <input
        class="search-input"
        placeholder="搜索订单、商家、商品"
        value="{{keyword}}"
        confirm-type="search"
        bindinput="handleSearchInput"
      />
      <text wx:if="{{keyword}}" class="clear-icon" bindtap="handleClearSearch">×</text>
    </view>

    <scroll-view class="status-scroll" scroll-x enable-flex>
      <view class="status-tabs">
        <view
          wx:for="{{tabs}}"
          wx:key="key"
          class="status-tab {{activeStatus === item.key ? 'active' : ''}}"
          data-key="{{item.key}}"
          bindtap="handleTabTap"
        >
          <text>{{item.title}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <view wx:if="{{emptyText}}" class="empty-card">
    <text class="empty-title">暂无订单</text>
    <text class="empty-copy">{{emptyText}}</text>
  </view>

  <view wx:for="{{visibleOrders}}" wx:key="id" class="order-card" data-id="{{item.id}}" bindtap="handleOrderTap">
    <view class="card-head">
      <view class="merchant">
        <image wx:if="{{item.imageUrl}}" class="merchant-image" src="{{item.imageUrl}}" mode="aspectFill"></image>
        <view wx:else class="merchant-fallback">店</view>
        <view class="merchant-copy">
          <text class="shop-name">{{item.shopName}}</text>
          <text class="order-time">{{item.time}}</text>
        </view>
      </view>
      <text class="status-pill {{item.statusTone}}">{{item.status}}</text>
    </view>

    <view class="order-body">
      <view class="item-copy">
        <text class="subtitle">{{item.subtitle}}</text>
        <text wx:if="{{item.eta}}" class="eta">{{item.eta}}</text>
      </view>
      <text class="amount">¥{{item.amount}}</text>
    </view>

    <view class="action-row">
      <button
        wx:if="{{item.secondaryAction}}"
        class="action-button ghost"
        size="mini"
        data-id="{{item.id}}"
        data-key="{{item.secondaryActionKey}}"
        catchtap="handleActionTap"
      >{{item.secondaryAction}}</button>
      <button
        class="action-button primary {{item.primaryActionKey === 'review' ? 'warm' : ''}}"
        size="mini"
        data-id="{{item.id}}"
        data-key="{{item.primaryActionKey}}"
        catchtap="handleActionTap"
      >{{item.primaryAction}}</button>
    </view>
  </view>
</view>
