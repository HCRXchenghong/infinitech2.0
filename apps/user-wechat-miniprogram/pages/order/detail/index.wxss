.page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
  background: #f3f4f6;
}

.status-card,
.section {
  margin-bottom: 18rpx;
  padding: 24rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 16rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.status {
  display: block;
  color: #009bf5;
  font-size: 36rpx;
  font-weight: 800;
}

.order-id {
  display: block;
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.amount {
  display: block;
  margin-top: 20rpx;
  color: #111827;
  font-size: 34rpx;
  font-weight: 800;
}

.section-title {
  display: block;
  margin-bottom: 16rpx;
  color: #111827;
  font-size: 30rpx;
  font-weight: 700;
}

.row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 10rpx 0;
  color: #374151;
  font-size: 26rpx;
}

.event-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 12rpx 0;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #009bf5;
}

.event-text {
  color: #374151;
  font-size: 26rpx;
}
