.rx-page {
  min-height: 100vh;
  padding: 28rpx 32rpx 150rpx;
  background: #f3f6f9;
  box-sizing: border-box;
}

.plain-nav {
  display: grid;
  grid-template-columns: 72rpx 1fr 120rpx;
  align-items: center;
  padding: calc(env(safe-area-inset-top) + 20rpx) 0 26rpx;
}

.nav-back {
  color: #111827;
  font-size: 56rpx;
  line-height: 50rpx;
}

.nav-title {
  color: #111827;
  font-size: 38rpx;
  font-weight: 900;
  text-align: center;
}

.product-card,
.card,
.guard-card {
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.05);
}

.product-card {
  position: relative;
  display: grid;
  grid-template-columns: 150rpx 1fr;
  gap: 24rpx;
  align-items: center;
  padding: 28rpx;
}

.medicine-box {
  width: 132rpx;
  height: 132rpx;
  border-radius: 16rpx;
  color: #007aff;
  background: #eef6ff;
  text-align: center;
  line-height: 132rpx;
  font-size: 42rpx;
  font-weight: 900;
}

.product-title,
.section-title {
  display: block;
  color: #111827;
  font-size: 34rpx;
  font-weight: 900;
}

.product-name {
  display: block;
  margin-top: 14rpx;
  color: #111827;
  font-size: 29rpx;
}

.product-name text {
  margin-left: 12rpx;
  padding: 3rpx 10rpx;
  border-radius: 8rpx;
  color: #ff4d00;
  border: 1rpx solid #ff8a4c;
  font-size: 23rpx;
}

.product-price {
  display: block;
  margin-top: 14rpx;
  color: #ff4d00;
  font-size: 38rpx;
  font-weight: 900;
}

.product-tip {
  display: block;
  margin-top: 14rpx;
  color: #667085;
  font-size: 25rpx;
}

.upload-state {
  position: absolute;
  right: 26rpx;
  top: 92rpx;
  padding: 8rpx 14rpx;
  border-radius: 10rpx;
  color: #ff4d00;
  border: 1rpx solid #ff8a4c;
  font-size: 25rpx;
}

.upload-state.uploading {
  color: #007aff;
  border-color: #007aff;
}

.upload-state.scanned {
  color: #059669;
  border-color: #34d399;
}

.card {
  margin-top: 18rpx;
  padding: 28rpx;
}

.upload-box {
  display: flex;
  min-height: 250rpx;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-top: 20rpx;
  border: 2rpx dashed #007aff;
  border-radius: 16rpx;
  color: #667085;
  font-size: 26rpx;
  text-align: center;
}

.upload-box text:nth-child(2) {
  color: #007aff;
  font-size: 34rpx;
  font-weight: 900;
}

.upload-box .scan-hint {
  color: #059669;
  font-size: 24rpx;
  font-weight: 700;
}

.camera {
  color: #007aff;
  font-size: 56rpx;
  font-weight: 900;
}

.camera-button {
  width: 220rpx;
  height: 62rpx;
  margin-top: 20rpx;
  border-radius: 31rpx;
  color: #007aff;
  background: #ffffff;
  line-height: 62rpx;
  font-size: 30rpx;
  font-weight: 900;
  padding: 0;
}

.camera-button[disabled] {
  color: #98a2b3;
  border-color: #d0d5dd;
}

.info-row {
  display: grid;
  grid-template-columns: 150rpx 1fr;
  gap: 20rpx;
  align-items: center;
  min-height: 82rpx;
  border-bottom: 1rpx solid #edf1f5;
  color: #667085;
  font-size: 28rpx;
}

.info-row:last-child {
  border-bottom: none;
}

.info-row input,
.info-row text:last-child {
  color: #374151;
  text-align: right;
  font-size: 28rpx;
}

.audit-row {
  display: grid;
  grid-template-columns: 1fr 170rpx 150rpx;
  gap: 14rpx;
  align-items: center;
  margin-top: 18rpx;
}

.audit-row text {
  color: #667085;
  font-size: 27rpx;
}

.audit-row button {
  height: 58rpx;
  border-radius: 10rpx;
  color: #007aff;
  background: #ffffff;
  border: 1rpx solid #007aff;
  line-height: 58rpx;
  font-size: 25rpx;
  padding: 0;
}

.guard-card {
  margin-top: 18rpx;
  padding: 22rpx 28rpx;
}

.guard-card text {
  display: block;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.6;
}

.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -10rpx 30rpx rgba(15, 23, 42, 0.08);
}

.bottom-actions button {
  height: 82rpx;
  border-radius: 14rpx;
  color: #ffffff;
  background: #007aff;
  line-height: 82rpx;
  font-size: 32rpx;
  font-weight: 900;
  padding: 0;
}

.bottom-actions button.ghost {
  color: #007aff;
  background: #ffffff;
  border: 1rpx solid #007aff;
}

button::after {
  border: none;
}
