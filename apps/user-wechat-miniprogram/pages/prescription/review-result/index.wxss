.rx-result-page {
  min-height: 100vh;
  padding: 28rpx 32rpx 150rpx;
  background: #f3f6f9;
  box-sizing: border-box;
}

.plain-nav {
  display: grid;
  grid-template-columns: 72rpx 1fr 120rpx;
  align-items: center;
  padding: calc(env(safe-area-inset-top) + 20rpx) 0 26rpx;
}

.nav-back {
  color: #111827;
  font-size: 56rpx;
  line-height: 50rpx;
}

.nav-title {
  color: #111827;
  font-size: 38rpx;
  font-weight: 900;
  text-align: center;
}

.result-hero,
.product-card,
.card,
.delivery-card,
.contact-card {
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.05);
}

.result-hero {
  position: relative;
  display: grid;
  grid-template-columns: 110rpx 1fr;
  gap: 24rpx;
  overflow: hidden;
  padding: 36rpx;
  border: 1rpx solid #bbf7d0;
  background: linear-gradient(90deg, #effdf5, #ffffff);
}

.check-icon {
  width: 82rpx;
  height: 82rpx;
  border-radius: 41rpx;
  color: #ffffff;
  background: #16c56f;
  text-align: center;
  line-height: 82rpx;
  font-size: 48rpx;
  font-weight: 900;
}

.result-title {
  display: block;
  color: #111827;
  font-size: 42rpx;
  font-weight: 900;
}

.result-meta,
.result-time {
  display: block;
  margin-top: 14rpx;
  color: #667085;
  font-size: 27rpx;
}

.watermark {
  position: absolute;
  right: 40rpx;
  top: 44rpx;
  color: rgba(22, 197, 111, 0.12);
  font-size: 150rpx;
  font-weight: 900;
}

.product-card {
  display: grid;
  grid-template-columns: 150rpx 1fr 170rpx;
  gap: 24rpx;
  align-items: center;
  margin-top: 20rpx;
  padding: 28rpx;
}

.medicine-box {
  width: 132rpx;
  height: 132rpx;
  border-radius: 16rpx;
  color: #007aff;
  background: #eef6ff;
  text-align: center;
  line-height: 132rpx;
  font-size: 42rpx;
  font-weight: 900;
}

.medicine-name,
.section-title {
  display: block;
  color: #111827;
  font-size: 34rpx;
  font-weight: 900;
}

.tag-row {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}

.tag-row text {
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  color: #ff4d00;
  border: 1rpx solid #ff8a4c;
  font-size: 23rpx;
}

.tag-row text:last-child {
  color: #16a34a;
  border-color: #86efac;
}

.medicine-price {
  display: block;
  margin-top: 14rpx;
  color: #ff4d00;
  font-size: 38rpx;
  font-weight: 900;
}

.medicine-note {
  display: block;
  margin-top: 10rpx;
  color: #667085;
  font-size: 25rpx;
}

.quantity {
  height: 62rpx;
  border-radius: 31rpx;
  color: #111827;
  background: #ffffff;
  border: 1rpx solid #d8dde6;
  text-align: center;
  line-height: 62rpx;
  font-size: 34rpx;
}

.quantity text {
  margin: 0 28rpx;
}

.card {
  margin-top: 18rpx;
  padding: 28rpx;
}

.info-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  min-height: 78rpx;
  border-bottom: 1rpx solid #edf1f5;
  color: #667085;
  font-size: 28rpx;
}

.info-row:last-child {
  border-bottom: none;
}

.info-row text:last-child {
  color: #374151;
  text-align: right;
}

.info-row.link text {
  color: #007aff;
  font-weight: 900;
}

.step-row {
  display: grid;
  grid-template-columns: 42rpx 1fr;
  gap: 18rpx;
  align-items: start;
  min-height: 82rpx;
}

.step-dot {
  width: 26rpx;
  height: 26rpx;
  margin-top: 8rpx;
  border-radius: 13rpx;
  background: #c5ccd6;
}

.step-row.done .step-dot {
  background: #16a34a;
}

.step-row.active .step-dot {
  background: #007aff;
}

.step-row text {
  display: block;
}

.step-row text:first-child {
  color: #111827;
  font-size: 29rpx;
  font-weight: 900;
}

.step-row text:last-child {
  margin-top: 6rpx;
  color: #667085;
  font-size: 25rpx;
}

.delivery-card {
  display: grid;
  grid-template-columns: 96rpx 1fr;
  gap: 20rpx;
  align-items: center;
  margin-top: 18rpx;
  padding: 28rpx;
}

.delivery-icon {
  width: 78rpx;
  height: 78rpx;
  border-radius: 39rpx;
  color: #007aff;
  background: #eef6ff;
  text-align: center;
  line-height: 78rpx;
  font-weight: 900;
}

.delivery-card text {
  display: block;
}

.delivery-card text:first-child {
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
}

.delivery-card text:last-child {
  margin-top: 10rpx;
  color: #667085;
  font-size: 26rpx;
}

.contact-card {
  display: grid;
  grid-template-columns: 1fr 170rpx 150rpx;
  gap: 14rpx;
  align-items: center;
  margin-top: 18rpx;
  padding: 24rpx;
}

.contact-card text {
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
}

.contact-card button {
  height: 58rpx;
  border-radius: 10rpx;
  color: #007aff;
  background: #ffffff;
  border: 1rpx solid #007aff;
  line-height: 58rpx;
  font-size: 25rpx;
  padding: 0;
}

.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: grid;
  grid-template-columns: 1fr 1.15fr;
  gap: 24rpx;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -10rpx 30rpx rgba(15, 23, 42, 0.08);
}

.bottom-actions button {
  height: 82rpx;
  border-radius: 14rpx;
  color: #ffffff;
  background: #007aff;
  line-height: 82rpx;
  font-size: 31rpx;
  font-weight: 900;
  padding: 0;
}

.bottom-actions button.ghost {
  color: #007aff;
  background: #ffffff;
  border: 1rpx solid #007aff;
}

button::after {
  border: none;
}
