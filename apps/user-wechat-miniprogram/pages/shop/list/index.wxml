<view class="page">
  <view class="nav">
    <text class="back" bindtap="handleBack">‹</text>
    <text class="nav-title">附近商家</text>
    <text class="nav-action">地图</text>
  </view>
  <view class="filters">
    <view wx:for="{{filters}}" wx:key="key" class="filter {{activeFilter === item.key ? 'active' : ''}}" data-key="{{item.key}}" bindtap="handleFilterTap">
      <text>{{item.title}}</text>
    </view>
  </view>

  <view class="shop-list">
    <view wx:for="{{shops}}" wx:key="id" class="shop-card" data-id="{{item.id}}" bindtap="handleShopTap">
      <view class="shop-image-frame">
        <image wx:if="{{item.imageUrl}}" class="shop-image" src="{{item.imageUrl}}" mode="aspectFill"></image>
        <text wx:else>{{item.initial}}</text>
      </view>
      <view class="shop-main">
        <view class="shop-head">
          <text class="shop-name">{{item.name}}</text>
          <text class="distance">{{item.distance}}</text>
        </view>
        <text class="shop-meta">{{item.category}} · {{item.rating}} 分 · {{item.monthlySales}}</text>
        <text class="shop-meta">{{item.delivery}}</text>
        <view class="tags">
          <text wx:for="{{item.tags}}" wx:key="*this" class="tag">{{item}}</text>
        </view>
        <text class="announcement">{{item.announcement}}</text>
      </view>
    </view>
  </view>
</view>
