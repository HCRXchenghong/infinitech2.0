.page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
  background: #f3f4f6;
}

.search-bar {
  display: flex;
  align-items: center;
  min-height: 76rpx;
  padding: 0 28rpx;
  border: 1rpx solid #dbeafe;
  border-radius: 12rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.search-placeholder {
  color: #6b7280;
  font-size: 26rpx;
}

.tabs {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.tab {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  color: #475569;
  background: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
}

.tab.active {
  color: #ffffff;
  background: #009bf5;
}

.shop-list {
  margin-top: 24rpx;
}

.shop-card {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
  padding: 24rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 16rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.shop-logo {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 108rpx;
  height: 108rpx;
  flex: 0 0 108rpx;
  border-radius: 14rpx;
  color: #ffffff;
  background: #009bf5;
  font-size: 30rpx;
  font-weight: 800;
  overflow: hidden;
}

.shop-logo-image {
  width: 100%;
  height: 100%;
}

.shop-main {
  min-width: 0;
  flex: 1;
}

.shop-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.shop-name {
  color: #111827;
  font-size: 32rpx;
  font-weight: 700;
}

.distance,
.shop-meta,
.announcement {
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.5;
}

.shop-meta,
.announcement {
  display: block;
  margin-top: 6rpx;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 10rpx;
}

.tag {
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  color: #007ccc;
  background: #e0f2fe;
  font-size: 22rpx;
}
