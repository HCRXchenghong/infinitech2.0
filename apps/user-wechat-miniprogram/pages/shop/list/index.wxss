.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 40rpx;
  box-sizing: border-box;
  background: #f3f4f6;
}

.nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(env(safe-area-inset-top) + 6rpx) 4rpx 22rpx;
}

.back,
.nav-action {
  width: 76rpx;
  color: #009bf5;
  font-size: 26rpx;
  font-weight: 800;
}

.back {
  color: #111827;
  font-size: 48rpx;
}

.nav-title {
  color: #111827;
  font-size: 34rpx;
  font-weight: 900;
}

.filters {
  display: flex;
  justify-content: space-between;
  gap: 10rpx;
  margin-bottom: 18rpx;
}

.filter {
  flex: 1;
  padding: 14rpx 8rpx;
  border-radius: 999rpx;
  color: #475569;
  background: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  text-align: center;
}

.filter.active {
  color: #ffffff;
  background: #009bf5;
}

.shop-list {
  margin-top: 0;
}

.shop-card {
  display: flex;
  gap: 18rpx;
  margin-bottom: 14rpx;
  padding: 20rpx;
  border-radius: 14rpx;
  background: #ffffff;
  box-sizing: border-box;
  box-shadow: 0 6rpx 18rpx rgba(15, 23, 42, 0.04);
}

.shop-image-frame {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 210rpx;
  height: 160rpx;
  flex: 0 0 210rpx;
  border-radius: 16rpx;
  color: #ffffff;
  background: #009bf5;
  font-size: 30rpx;
  font-weight: 800;
  overflow: hidden;
}

.shop-image {
  width: 100%;
  height: 100%;
}

.shop-main {
  min-width: 0;
  flex: 1;
}

.shop-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.shop-name {
  color: #111827;
  font-size: 30rpx;
  font-weight: 700;
}

.distance,
.shop-meta,
.announcement {
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.5;
}

.shop-meta,
.announcement {
  display: block;
  margin-top: 6rpx;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 10rpx;
}

.tag {
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  color: #007ccc;
  background: #e0f2fe;
  font-size: 22rpx;
}
