.ticket-page {
  min-height: 100vh;
  padding: 0 28rpx 150rpx;
  background: #f3f6f9;
  box-sizing: border-box;
}

.blue-nav {
  display: grid;
  grid-template-columns: 72rpx 1fr 150rpx;
  align-items: center;
  margin: 0 -28rpx;
  padding: calc(env(safe-area-inset-top) + 18rpx) 28rpx 24rpx;
  color: #ffffff;
  background: linear-gradient(90deg, #007aff, #00a5ff);
}

.nav-back {
  color: #ffffff;
  font-size: 58rpx;
  line-height: 52rpx;
}

.nav-title {
  font-size: 38rpx;
  font-weight: 900;
  text-align: center;
}

.nav-action {
  font-size: 27rpx;
  text-align: right;
}

.status-card,
.order-card,
.card,
.guard-card {
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.05);
}

.status-card {
  position: relative;
  display: grid;
  grid-template-columns: 96rpx 1fr;
  gap: 22rpx;
  align-items: center;
  margin-top: 28rpx;
  padding: 28rpx;
}

.status-icon,
.card-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  color: #ffffff;
  background: #007aff;
  text-align: center;
  line-height: 72rpx;
  font-size: 34rpx;
  font-weight: 900;
}

.status-title,
.section-title {
  display: block;
  color: #111827;
  font-size: 34rpx;
  font-weight: 900;
}

.status-meta {
  display: block;
  margin-top: 8rpx;
  color: #667085;
  font-size: 26rpx;
}

.status-pill {
  position: absolute;
  right: 28rpx;
  top: 34rpx;
  min-width: 116rpx;
  height: 52rpx;
  border-radius: 26rpx;
  color: #ff4d00;
  border: 1rpx solid #ff8a4c;
  text-align: center;
  line-height: 52rpx;
  font-size: 26rpx;
  font-weight: 900;
}

.sla-card {
  display: grid;
  grid-template-columns: 170rpx 1fr;
  gap: 18rpx;
  align-items: center;
  margin-top: 18rpx;
  padding: 22rpx 26rpx;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.05);
}

.sla-card.due {
  background: #fff7ed;
}

.sla-card.danger {
  background: #fff1f2;
}

.sla-card.done {
  background: #ecfdf3;
}

.sla-label,
.sla-desc {
  display: block;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.45;
}

.sla-title {
  display: block;
  margin-top: 6rpx;
  color: #111827;
  font-size: 32rpx;
  font-weight: 900;
}

.order-card {
  display: grid;
  grid-template-columns: 128rpx 1fr 150rpx;
  gap: 22rpx;
  align-items: center;
  margin-top: 18rpx;
  padding: 24rpx;
}

.food-thumb {
  width: 112rpx;
  height: 112rpx;
  border-radius: 14rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #8b5e34, #f59e0b);
  text-align: center;
  line-height: 112rpx;
  font-weight: 900;
}

.order-title {
  display: block;
  color: #111827;
  font-size: 31rpx;
  font-weight: 900;
}

.order-meta {
  display: block;
  margin-top: 8rpx;
  color: #667085;
  font-size: 25rpx;
}

.order-side {
  text-align: right;
}

.order-side text {
  display: block;
  color: #007aff;
  font-size: 26rpx;
}

.order-side text:first-child {
  color: #ff4d00;
  margin-bottom: 36rpx;
}

.card {
  margin-top: 18rpx;
  padding: 26rpx;
}

.card-title-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 16rpx;
}

.card-title-row text {
  color: #111827;
  font-size: 32rpx;
  font-weight: 900;
}

.card-icon {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  font-size: 24rpx;
}

.desc-type,
.desc-content,
.desc-time,
.solution {
  display: block;
  color: #667085;
  font-size: 27rpx;
  line-height: 1.55;
}

.desc-content {
  margin-top: 18rpx;
  color: #111827;
}

.desc-time {
  margin-top: 18rpx;
  font-size: 24rpx;
}

.timeline-row {
  display: grid;
  grid-template-columns: 42rpx 1fr 88rpx;
  gap: 18rpx;
  align-items: start;
  min-height: 108rpx;
}

.dot {
  width: 28rpx;
  height: 28rpx;
  border-radius: 14rpx;
  margin-top: 8rpx;
  background: #c5ccd6;
  box-shadow: 0 0 0 6rpx #ffffff, 0 0 0 8rpx #c5ccd6;
}

.timeline-row.done .dot {
  background: #007aff;
  box-shadow: 0 0 0 6rpx #ffffff, 0 0 0 8rpx #007aff;
}

.timeline-row.active .dot {
  background: #ffffff;
  box-shadow: 0 0 0 6rpx #ffffff, 0 0 0 8rpx #007aff;
}

.timeline-main text {
  display: block;
}

.timeline-main text:first-child {
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
}

.timeline-main text:last-child {
  margin-top: 8rpx;
  color: #667085;
  font-size: 25rpx;
}

.timeline-time {
  color: #007aff;
  font-size: 25rpx;
  text-align: right;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  margin-top: 22rpx;
}

.action-grid button,
.bottom-actions button {
  height: 72rpx;
  border-radius: 12rpx;
  color: #007aff;
  background: #ffffff;
  border: 1rpx solid #007aff;
  line-height: 72rpx;
  font-size: 29rpx;
  font-weight: 900;
  padding: 0;
}

.evidence-row {
  display: flex;
  gap: 24rpx;
  flex-wrap: wrap;
}

.evidence-row view {
  width: 150rpx;
  height: 96rpx;
  border-radius: 14rpx;
  color: #98a2b3;
  background: #eef1f5;
  text-align: center;
  line-height: 96rpx;
  font-size: 25rpx;
}

.evidence-row .add-evidence {
  color: #007aff;
  background: #ffffff;
  border: 1rpx dashed #98a2b3;
}

.guard-card {
  margin-top: 18rpx;
  padding: 20rpx 26rpx;
}

.guard-card text {
  display: block;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.6;
}

.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  padding: 20rpx 28rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -10rpx 30rpx rgba(15, 23, 42, 0.08);
}

.bottom-actions button {
  color: #ffffff;
  background: #007aff;
  border: none;
}

.bottom-actions button.ghost {
  color: #007aff;
  background: #ffffff;
  border: 1rpx solid #007aff;
}

button::after {
  border: none;
}
