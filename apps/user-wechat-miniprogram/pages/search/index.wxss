.search-page {
  min-height: 100vh;
  padding: 28rpx 28rpx 60rpx;
  background: #f3f6f9;
  box-sizing: border-box;
}

.plain-nav {
  display: grid;
  grid-template-columns: 72rpx 1fr 120rpx;
  align-items: center;
  padding: calc(env(safe-area-inset-top) + 20rpx) 0 24rpx;
}

.nav-back {
  color: #111827;
  font-size: 56rpx;
  line-height: 50rpx;
}

.nav-title {
  text-align: center;
  color: #111827;
  font-size: 36rpx;
  font-weight: 900;
}

.nav-action {
  color: #007aff;
  font-size: 24rpx;
  text-align: right;
}

.search-row {
  display: grid;
  grid-template-columns: 1fr 86rpx;
  gap: 22rpx;
  align-items: center;
}

.search-box {
  display: grid;
  grid-template-columns: 52rpx 1fr 44rpx;
  align-items: center;
  height: 76rpx;
  padding: 0 24rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1rpx solid #dce3ec;
  box-sizing: border-box;
}

.search-icon,
.clear-icon {
  color: #98a2b3;
  font-size: 34rpx;
  font-weight: 900;
}

.search-input {
  height: 76rpx;
  color: #111827;
  font-size: 30rpx;
}

.search-action {
  color: #007aff;
  font-size: 30rpx;
  font-weight: 900;
}

.category-row {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  margin-top: 28rpx;
  text-align: center;
}

.category {
  position: relative;
  padding: 16rpx 0 24rpx;
  color: #111827;
  font-size: 30rpx;
}

.category.active {
  color: #007aff;
  font-weight: 900;
}

.category.active::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: 8rpx;
  width: 54rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: #007aff;
  transform: translateX(-50%);
}

.guess-card,
.result-head,
.result-card,
.empty-card,
.tip-row {
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.05);
}

.guess-card {
  margin-top: 8rpx;
  padding: 28rpx;
}

.guess-head {
  display: flex;
  justify-content: space-between;
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
}

.guess-head text:last-child {
  color: #667085;
  font-size: 26rpx;
  font-weight: 500;
}

.suggestion-row {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 24rpx;
}

.suggestion {
  height: 50rpx;
  padding: 0 22rpx;
  border-radius: 25rpx;
  color: #374151;
  background: #eef1f5;
  font-size: 26rpx;
  line-height: 50rpx;
}

.result-head {
  margin-top: 22rpx;
  padding: 28rpx;
  color: #111827;
  font-size: 30rpx;
}

.sort-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #edf1f5;
  color: #667085;
  font-size: 26rpx;
}

.sort-row text:first-child {
  color: #007aff;
}

.result-card {
  display: grid;
  grid-template-columns: 154rpx 1fr 138rpx;
  gap: 22rpx;
  align-items: center;
  margin-top: 12rpx;
  padding: 22rpx;
}

.result-thumb {
  width: 154rpx;
  height: 132rpx;
  border-radius: 16rpx;
  color: #007aff;
  background: linear-gradient(135deg, #eaf4ff, #dbeafe);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 900;
  overflow: hidden;
}

.result-image {
  display: block;
  width: 154rpx;
  height: 132rpx;
}

.result-card.product .result-thumb {
  color: #ff4d00;
  background: #fff1e8;
}

.result-card.groupbuy .result-thumb {
  color: #ff4d00;
  background: #fff5f0;
}

.result-card.medicine .result-thumb {
  color: #16a34a;
  background: #ecfdf3;
}

.result-card.errand .result-thumb {
  color: #007aff;
  background: #eef6ff;
}

.result-main {
  min-width: 0;
}

.result-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.result-title {
  color: #111827;
  font-size: 32rpx;
  font-weight: 900;
}

.type-badge {
  padding: 4rpx 8rpx;
  border-radius: 6rpx;
  color: #007aff;
  background: #eef6ff;
  font-size: 22rpx;
}

.result-subtitle,
.result-distance {
  display: block;
  margin-top: 10rpx;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.4;
}

.result-price {
  display: block;
  margin-top: 10rpx;
  color: #ff3b30;
  font-size: 34rpx;
  font-weight: 900;
}

.result-button {
  height: 62rpx;
  border-radius: 14rpx;
  color: #007aff;
  background: #ffffff;
  border: 2rpx solid #007aff;
  font-size: 26rpx;
  line-height: 62rpx;
  padding: 0;
}

.result-button::after {
  border: none;
}

.empty-card {
  margin-top: 14rpx;
  padding: 46rpx 28rpx;
  text-align: center;
}

.empty-title,
.empty-copy {
  display: block;
}

.empty-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
}

.empty-copy {
  margin-top: 12rpx;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.5;
}

.tip-row {
  margin-top: 22rpx;
  padding: 22rpx;
  color: #667085;
  font-size: 26rpx;
  background: #f2f8ff;
  border: 1rpx solid #d7eaff;
}
