.page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
  background: #f3f4f6;
}

.title {
  display: block;
  color: #009bf5;
  font-size: 40rpx;
  font-weight: 700;
}

.requirement {
  margin-top: 18rpx;
  padding: 24rpx;
  border: 1rpx solid #dbeafe;
  border-radius: 16rpx;
  color: #111827;
  background: #ffffff;
  font-size: 26rpx;
}
