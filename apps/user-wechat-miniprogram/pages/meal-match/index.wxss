.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 160rpx;
  box-sizing: border-box;
  background: #f3f4f6;
}

.intro-card,
.card,
.privacy-card,
.safe-card {
  margin-bottom: 18rpx;
  padding: 28rpx;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.04);
  box-sizing: border-box;
}

.intro-card {
  background: linear-gradient(135deg, #e0f2fe, #ffffff);
}

.privacy-card {
  display: grid;
  grid-template-columns: 1fr 150rpx;
  gap: 18rpx;
  align-items: center;
  background: #eefdf5;
  border: 1rpx solid #bbf7d0;
}

.privacy-line {
  display: block;
  margin-top: 8rpx;
  color: #166534;
  font-size: 24rpx;
  line-height: 1.45;
}

.privacy-badge {
  height: 58rpx;
  border-radius: 29rpx;
  color: #ffffff;
  background: #16a34a;
  text-align: center;
  line-height: 58rpx;
  font-size: 23rpx;
  font-weight: 900;
}

.eyebrow {
  display: block;
  color: #009bf5;
  font-size: 24rpx;
  font-weight: 800;
}

.title {
  display: block;
  margin-top: 10rpx;
  color: #111827;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.35;
}

.status {
  display: inline-flex;
  margin-top: 18rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #009bf5;
  color: #ffffff;
  font-size: 23rpx;
  font-weight: 800;
}

.section-title {
  display: block;
  margin-bottom: 16rpx;
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
}

.requirement {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #eef2f7;
}

.requirement:last-child {
  border-bottom: none;
}

.check {
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  background: #fef3c7;
  color: #b45309;
  text-align: center;
  line-height: 44rpx;
  font-weight: 900;
}

.check.done {
  background: #dcfce7;
  color: #16a34a;
}

.requirement-title {
  flex: 1;
  color: #111827;
  background: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
}

.requirement-status,
.distance {
  color: #009bf5;
  font-size: 23rpx;
  font-weight: 800;
}

.buddy-card {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #eef2f7;
}

.buddy-card:last-child {
  border-bottom: none;
}

.empty-state {
  padding: 28rpx 22rpx;
  border-radius: 14rpx;
  background: #f8fafc;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.6;
}

.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  background: #e0f2fe;
  color: #009bf5;
  text-align: center;
  line-height: 64rpx;
  font-weight: 900;
}

.buddy-main {
  flex: 1;
  min-width: 0;
}

.buddy-title,
.buddy-subtitle {
  display: block;
}

.buddy-title {
  color: #111827;
  font-size: 27rpx;
  font-weight: 800;
}

.buddy-subtitle {
  margin-top: 6rpx;
  color: #6b7280;
  font-size: 23rpx;
}

.privacy {
  display: block;
  margin-top: 8rpx;
  color: #94a3b8;
  font-size: 21rpx;
  line-height: 1.4;
}

.location-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 10rpx;
}

.location-row text {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  color: #0369a1;
  background: #e0f2fe;
  font-size: 20rpx;
  font-weight: 800;
}

.buddy-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 14rpx;
}

.buddy-actions button {
  height: 48rpx;
  line-height: 46rpx;
  margin: 0;
  padding: 0 18rpx;
  border-radius: 24rpx;
  background: #f8fafc;
  color: #475569;
  font-size: 22rpx;
}

.buddy-actions button::after {
  border: none;
}

.buddy-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  flex-shrink: 0;
}

.score {
  color: #16a34a;
  font-size: 22rpx;
  font-weight: 900;
}

.safe-card {
  color: #92400e;
  background: #fff7ed;
  font-size: 24rpx;
  line-height: 1.6;
}

.bottom {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -8rpx 22rpx rgba(15, 23, 42, 0.08);
}

.start-button {
  border-radius: 14rpx;
  background: #009bf5;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
}
