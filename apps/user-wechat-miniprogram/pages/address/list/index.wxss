.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 160rpx;
  box-sizing: border-box;
  background: #f3f4f6;
}

.status {
  display: block;
  color: #009bf5;
  font-size: 24rpx;
  font-weight: 700;
}

.hint {
  display: block;
  margin: 8rpx 0 20rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.empty-card {
  margin-bottom: 18rpx;
  padding: 34rpx 26rpx;
  border: 2rpx dashed #cfe9ff;
  border-radius: 18rpx;
  color: #64748b;
  background: #f8fbff;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.45;
  text-align: center;
}

.address-card {
  margin-bottom: 18rpx;
  padding: 24rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 16rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.address-card.selected {
  border-color: rgba(0, 155, 245, 0.42);
  box-shadow: 0 8rpx 24rpx rgba(0, 155, 245, 0.12);
}

.head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.tag,
.default,
.selected-badge {
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.tag {
  color: #007ccc;
  background: #e0f2fe;
}

.default {
  color: #ffffff;
  background: #009bf5;
  margin-left: 10rpx;
}

.selected-badge {
  margin-left: 10rpx;
  color: #0f766e;
  background: #ecfeff;
}

.edit-icon {
  color: #009bf5;
  font-size: 24rpx;
  font-weight: 700;
}

.detail {
  display: block;
  margin-top: 16rpx;
  color: #111827;
  font-size: 32rpx;
  font-weight: 700;
}

.contact {
  display: block;
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.actions {
  display: flex;
  gap: 28rpx;
  margin-top: 22rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #eef2f7;
  color: #009bf5;
  font-size: 24rpx;
  font-weight: 700;
}

.actions .danger {
  color: #ef4444;
}

.bottom {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -8rpx 22rpx rgba(15, 23, 42, 0.08);
}

.add-button {
  border-radius: 10rpx;
  color: #ffffff;
  background: #009bf5;
  font-size: 26rpx;
}
