.group-settings-page {
  min-height: 100vh;
  padding: 28rpx 28rpx 48rpx;
  background: #f3f6f9;
  box-sizing: border-box;
}

.plain-nav {
  display: grid;
  grid-template-columns: 72rpx 1fr 72rpx;
  align-items: center;
  padding: calc(env(safe-area-inset-top) + 20rpx) 0 26rpx;
}

.nav-back {
  color: #111827;
  font-size: 56rpx;
  line-height: 50rpx;
}

.nav-title {
  color: #111827;
  font-size: 36rpx;
  font-weight: 900;
  text-align: center;
}

.nav-spacer {
  width: 72rpx;
}

.hero-card,
.section-card {
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.05);
}

.hero-card {
  display: grid;
  grid-template-columns: 92rpx 1fr auto;
  gap: 22rpx;
  align-items: center;
  padding: 28rpx;
}

.hero-icon,
.member-avatar {
  width: 78rpx;
  height: 78rpx;
  border-radius: 18rpx;
  color: #ffffff;
  background: #007aff;
  text-align: center;
  line-height: 78rpx;
  font-size: 32rpx;
  font-weight: 900;
}

.hero-title,
.section-title,
.member-name {
  display: block;
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
}

.hero-summary,
.section-copy,
.notice-copy,
.member-role,
.member-count,
.member-footnote {
  display: block;
  color: #667085;
  font-size: 24rpx;
}

.hero-summary,
.section-copy,
.notice-copy {
  margin-top: 8rpx;
  line-height: 1.6;
}

.hero-badge {
  padding: 12rpx 18rpx;
  border-radius: 24rpx;
  color: #007aff;
  background: rgba(0, 122, 255, 0.1);
  font-size: 22rpx;
  font-weight: 900;
}

.hero-badge.joined {
  color: #ff5a1f;
  background: rgba(255, 90, 31, 0.1);
}

.section-card {
  margin-top: 18rpx;
  padding: 26rpx 28rpx;
}

.section-row,
.member-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.section-inline-action {
  margin-top: 18rpx;
  color: #007aff;
  font-size: 26rpx;
  font-weight: 900;
}

.member-list {
  margin-top: 22rpx;
}

.member-item {
  display: grid;
  grid-template-columns: 78rpx 1fr;
  gap: 18rpx;
  align-items: center;
  padding: 18rpx 0;
  margin-bottom: 16rpx;
  border-bottom: 1rpx solid #eef2f6;
}

.member-item:last-child {
  margin-bottom: 0;
  border-bottom: none;
}

.member-role {
  margin-top: 6rpx;
}

.member-footnote {
  margin-top: 18rpx;
  line-height: 1.6;
}

.danger-card {
  border: 1rpx solid rgba(255, 59, 48, 0.16);
}

.danger-action {
  margin-top: 18rpx;
  color: #ff3b30;
  font-size: 26rpx;
  font-weight: 900;
}
