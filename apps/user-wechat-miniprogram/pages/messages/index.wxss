.messages-page {
  min-height: 100vh;
  padding: 0 28rpx calc(132rpx + env(safe-area-inset-bottom));
  background:
    linear-gradient(180deg, #eaf5ff 0, #eef8ff 310rpx, #f6f9fd 100%);
  box-sizing: border-box;
}

.mp-nav {
  margin: 0 -28rpx;
}

.message-search {
  height: 86rpx;
  margin-top: 6rpx;
  padding: 0 26rpx;
  border: 2rpx solid rgba(205, 217, 230, 0.9);
  border-radius: 43rpx;
  background: rgba(255, 255, 255, 0.98);
  display: grid;
  grid-template-columns: 42rpx minmax(0, 1fr) 34rpx;
  align-items: center;
  gap: 14rpx;
  box-shadow: 0 12rpx 34rpx rgba(52, 83, 125, 0.06);
  box-sizing: border-box;
}

.search-icon,
.clear-icon {
  color: #9aa8ba;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1;
}

.clear-icon {
  text-align: right;
}

.search-input {
  min-width: 0;
  height: 84rpx;
  color: #111827;
  font-size: 29rpx;
  font-weight: 700;
}

.conversation-card {
  margin-top: 24rpx;
  padding: 8rpx 26rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 14rpx 36rpx rgba(52, 83, 125, 0.08);
  box-sizing: border-box;
}

.conversation-row {
  min-height: 126rpx;
  display: grid;
  grid-template-columns: 82rpx minmax(0, 1fr) 86rpx;
  align-items: center;
  gap: 20rpx;
  border-bottom: 1rpx solid #eef2f7;
}

.conversation-row:last-child {
  border-bottom: none;
}

.row-icon-shell {
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  background: #eef8ff;
  overflow: hidden;
  box-shadow: 0 8rpx 18rpx rgba(21, 156, 255, 0.1);
  box-sizing: border-box;
}

.row-icon {
  width: 72rpx;
  height: 72rpx;
  display: block;
}

.row-icon-shell.rider {
  background: #eef9ff;
}

.row-icon-shell.group {
  background: #f3f1ff;
}

.row-icon-shell.service {
  background: #159cff;
}

.row-main {
  min-width: 0;
}

.row-title-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.row-title,
.row-preview,
.row-time {
  display: block;
}

.row-title {
  color: #111827;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 1.28;
  letter-spacing: 0;
}

.mute-tag {
  flex: 0 0 auto;
  height: 30rpx;
  padding: 0 12rpx;
  border-radius: 15rpx;
  background: #eef3f8;
  color: #8a98aa;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 30rpx;
}

.row-preview {
  margin-top: 10rpx;
  color: #738196;
  font-size: 25rpx;
  font-weight: 600;
  line-height: 1.35;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.row-side {
  min-height: 76rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: space-between;
}

.row-time {
  color: #9aa8ba;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.2;
  white-space: nowrap;
}

.unread-badge {
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 10rpx;
  border-radius: 17rpx;
  background: #159cff;
  color: #ffffff;
  text-align: center;
  line-height: 34rpx;
  font-size: 20rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.unread-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 8rpx;
  background: #159cff;
}
