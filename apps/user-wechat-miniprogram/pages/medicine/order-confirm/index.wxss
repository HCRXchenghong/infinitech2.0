.medicine-confirm-page {
  min-height: 100vh;
  padding: 28rpx 32rpx 150rpx;
  background: #f3f6f9;
  box-sizing: border-box;
}

.plain-nav {
  display: grid;
  grid-template-columns: 72rpx 1fr 120rpx;
  align-items: center;
  padding: calc(env(safe-area-inset-top) + 20rpx) 0 26rpx;
}

.nav-back {
  color: #111827;
  font-size: 56rpx;
  line-height: 50rpx;
}

.nav-title {
  color: #111827;
  font-size: 38rpx;
  font-weight: 900;
  text-align: center;
}

.address-card,
.clinic-card,
.card,
.remark-card,
.advice-row {
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.05);
}

.address-card {
  display: grid;
  grid-template-columns: 86rpx 1fr 32rpx;
  gap: 22rpx;
  align-items: center;
  padding: 32rpx;
}

.address-icon,
.clinic-icon {
  width: 70rpx;
  height: 70rpx;
  border-radius: 35rpx;
  color: #ffffff;
  background: #007aff;
  text-align: center;
  line-height: 70rpx;
  font-weight: 900;
}

.address-card text,
.clinic-card text {
  display: block;
}

.address-card view text:first-child,
.clinic-card view text:first-child,
.section-title {
  color: #111827;
  font-size: 34rpx;
  font-weight: 900;
}

.address-card view text:nth-child(2) {
  margin-top: 12rpx;
  color: #111827;
  font-size: 34rpx;
  font-weight: 900;
}

.address-card view text:nth-child(3),
.clinic-card view text:nth-child(2),
.clinic-card view text:nth-child(3) {
  margin-top: 10rpx;
  color: #667085;
  font-size: 26rpx;
}

.address-card view text:last-child {
  display: inline-block;
  width: fit-content;
  margin-top: 14rpx;
  padding: 4rpx 10rpx;
  color: #16a34a;
  border: 1rpx solid #86efac;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.address-card > text {
  color: #374151;
  font-size: 48rpx;
}

.clinic-card {
  display: grid;
  grid-template-columns: 86rpx 1fr;
  gap: 22rpx;
  align-items: center;
  margin-top: 18rpx;
  padding: 28rpx;
}

.clinic-icon {
  background: #16a34a;
  font-size: 42rpx;
}

.card {
  margin-top: 18rpx;
  padding: 28rpx;
}

.section-title {
  display: block;
  margin-bottom: 18rpx;
}

.item-row {
  display: grid;
  grid-template-columns: 112rpx 1fr 70rpx 116rpx;
  gap: 18rpx;
  align-items: center;
  padding: 18rpx 0;
}

.medicine-box {
  width: 94rpx;
  height: 94rpx;
  border-radius: 14rpx;
  color: #007aff;
  background: #eef6ff;
  text-align: center;
  line-height: 94rpx;
  font-weight: 900;
  overflow: hidden;
}

.medicine-image {
  display: block;
  width: 94rpx;
  height: 94rpx;
}

.item-name {
  display: block;
  color: #111827;
  font-size: 31rpx;
  font-weight: 900;
}

.tag-row {
  display: flex;
  gap: 10rpx;
  margin-top: 10rpx;
}

.tag-row text {
  padding: 3rpx 8rpx;
  border-radius: 7rpx;
  color: #16a34a;
  border: 1rpx solid #86efac;
  font-size: 22rpx;
}

.tag-row text:first-child {
  color: #ff4d00;
  border-color: #ff8a4c;
}

.item-note {
  display: block;
  margin-top: 8rpx;
  color: #667085;
  font-size: 24rpx;
}

.item-row > text {
  color: #111827;
  font-size: 28rpx;
  text-align: right;
}

.item-row > text:last-child {
  font-weight: 900;
}

.rx-pass {
  display: flex;
  justify-content: space-between;
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 12rpx;
  background: #effdf5;
  color: #16a34a;
  font-size: 26rpx;
  font-weight: 800;
}

.fee-row,
.remark-card {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 78rpx;
  align-items: center;
  border-bottom: 1rpx solid #edf1f5;
  color: #667085;
  font-size: 28rpx;
}

.fee-row:last-child {
  border-bottom: none;
}

.fee-row text:last-child,
.remark-card text:last-child {
  color: #374151;
  text-align: right;
}

.remark-card {
  margin-top: 18rpx;
  padding: 0 28rpx;
}

.advice-row {
  margin-top: 18rpx;
  padding: 18rpx 24rpx;
  color: #16a34a;
  background: #effdf5;
  font-size: 25rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: grid;
  grid-template-columns: 1fr 390rpx;
  gap: 24rpx;
  align-items: center;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -10rpx 30rpx rgba(15, 23, 42, 0.08);
}

.bottom-bar text:first-child {
  color: #111827;
  font-size: 31rpx;
}

.bottom-bar text:last-child {
  margin-left: 16rpx;
  color: #007aff;
  font-size: 42rpx;
  font-weight: 900;
}

.bottom-bar button {
  height: 82rpx;
  border-radius: 14rpx;
  color: #ffffff;
  background: #007aff;
  line-height: 82rpx;
  font-size: 32rpx;
  font-weight: 900;
  padding: 0;
}

button::after {
  border: none;
}
