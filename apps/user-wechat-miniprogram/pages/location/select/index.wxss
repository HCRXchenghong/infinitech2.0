.location-page {
  min-height: 100vh;
  padding: 0 28rpx 164rpx;
  box-sizing: border-box;
  background:
    linear-gradient(180deg, #eaf5ff 0, #eef8ff 320rpx, #f6f9fd 100%);
  color: #111827;
}

.location-nav {
  margin: 0 -28rpx;
  padding-left: 28rpx !important;
}

.search-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 116rpx;
  gap: 16rpx;
  align-items: center;
  margin-top: 4rpx;
}

.search-box {
  height: 82rpx;
  padding: 0 24rpx;
  border: 2rpx solid rgba(205, 217, 230, 0.9);
  border-radius: 41rpx;
  background: rgba(255, 255, 255, 0.98);
  display: grid;
  grid-template-columns: 42rpx minmax(0, 1fr) 34rpx;
  align-items: center;
  gap: 12rpx;
  box-sizing: border-box;
  box-shadow: 0 12rpx 30rpx rgba(52, 83, 125, 0.06);
}

.search-icon,
.clear-icon {
  color: #9aa8ba;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1;
}

.search-input {
  min-width: 0;
  height: 80rpx;
  color: #111827;
  font-size: 28rpx;
  font-weight: 700;
}

.search-button {
  height: 72rpx;
  border-radius: 36rpx;
  background: #159cff;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 72rpx;
  text-align: center;
  box-shadow: 0 12rpx 24rpx rgba(21, 156, 255, 0.22);
}

.current-card,
.section-card,
.map-card,
.frequent-card {
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 14rpx 36rpx rgba(52, 83, 125, 0.08);
  box-sizing: border-box;
}

.current-card {
  display: grid;
  grid-template-columns: 62rpx minmax(0, 1fr) 142rpx;
  align-items: center;
  gap: 18rpx;
  margin-top: 22rpx;
  padding: 24rpx;
  border: 2rpx solid transparent;
  border-radius: 28rpx;
}

.current-card.selected,
.place-row.selected,
.frequent-card.selected {
  border-color: rgba(21, 156, 255, 0.48);
  background: #f8fcff;
}

.pin-mark {
  width: 54rpx;
  height: 62rpx;
  border-radius: 30rpx 30rpx 30rpx 6rpx;
  background: linear-gradient(180deg, #2eb3ff, #087be8);
  transform: rotate(-45deg);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 20rpx rgba(21, 156, 255, 0.24);
}

.pin-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 10rpx;
  background: #ffffff;
}

.current-main {
  min-width: 0;
}

.current-head,
.place-title-row,
.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.current-label,
.selected-tag,
.distance {
  display: inline-flex;
  align-items: center;
  min-height: 34rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 900;
}

.current-label {
  color: #159cff;
  background: #eaf7ff;
}

.selected-tag {
  color: #0f766e;
  background: #ecfeff;
}

.current-title {
  display: block;
  margin-top: 10rpx;
  color: #111827;
  font-size: 33rpx;
  font-weight: 900;
  line-height: 1.25;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.current-subtitle,
.place-address,
.frequent-address,
.map-tip {
  display: block;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.45;
}

.current-subtitle {
  margin-top: 6rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.relocate-button {
  height: 58rpx;
  border-radius: 29rpx;
  color: #159cff;
  background: #eaf7ff;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 58rpx;
  text-align: center;
}

.map-card {
  position: relative;
  height: 236rpx;
  margin-top: 20rpx;
  border-radius: 30rpx;
  overflow: hidden;
  background:
    linear-gradient(135deg, rgba(224, 242, 254, 0.9), rgba(244, 250, 255, 0.96));
}

.map-grid,
.map-road {
  position: absolute;
  border-radius: 999rpx;
  background: rgba(21, 156, 255, 0.12);
}

.map-grid-a {
  left: -30rpx;
  top: 46rpx;
  width: 320rpx;
  height: 18rpx;
  transform: rotate(-14deg);
}

.map-grid-b {
  right: -20rpx;
  top: 112rpx;
  width: 420rpx;
  height: 16rpx;
  transform: rotate(16deg);
}

.map-grid-c {
  left: 160rpx;
  bottom: 42rpx;
  width: 380rpx;
  height: 14rpx;
  transform: rotate(-8deg);
}

.map-road-a {
  left: 86rpx;
  top: -60rpx;
  width: 22rpx;
  height: 340rpx;
  transform: rotate(22deg);
  background: rgba(148, 163, 184, 0.12);
}

.map-road-b {
  right: 150rpx;
  top: -34rpx;
  width: 20rpx;
  height: 310rpx;
  transform: rotate(-28deg);
  background: rgba(148, 163, 184, 0.12);
}

.map-pin {
  position: absolute;
  left: 50%;
  top: 78rpx;
  width: 58rpx;
  height: 68rpx;
  margin-left: -29rpx;
  border-radius: 34rpx 34rpx 34rpx 8rpx;
  background: linear-gradient(180deg, #2eb3ff, #087be8);
  transform: rotate(-45deg);
  box-shadow: 0 16rpx 26rpx rgba(21, 156, 255, 0.28);
}

.map-pin-core {
  position: absolute;
  left: 18rpx;
  top: 18rpx;
  width: 22rpx;
  height: 22rpx;
  border-radius: 11rpx;
  background: #ffffff;
}

.map-tip {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 24rpx;
  text-align: center;
  color: #516173;
  font-weight: 700;
}

.section-card,
.frequent-section {
  margin-top: 22rpx;
}

.section-card {
  padding: 26rpx 24rpx 8rpx;
  border-radius: 28rpx;
}

.section-title {
  color: #111827;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.25;
}

.section-more {
  color: #8793a5;
  font-size: 25rpx;
  font-weight: 800;
}

.place-row {
  display: grid;
  grid-template-columns: 58rpx minmax(0, 1fr) 30rpx;
  align-items: center;
  gap: 16rpx;
  margin-top: 18rpx;
  padding: 18rpx;
  border: 2rpx solid transparent;
  border-radius: 22rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.empty-row {
  margin-top: 20rpx;
  padding: 26rpx 18rpx;
  border: 2rpx dashed #dbeafe;
  border-radius: 20rpx;
  color: #64748b;
  background: #f8fbff;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.45;
  text-align: center;
}

.place-icon,
.frequent-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #159cff;
  background: #eaf7ff;
  font-weight: 900;
}

.place-icon {
  width: 54rpx;
  height: 54rpx;
  border-radius: 18rpx;
  font-size: 24rpx;
}

.place-main {
  min-width: 0;
}

.place-title {
  min-width: 0;
  color: #111827;
  font-size: 29rpx;
  font-weight: 900;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.distance {
  flex-shrink: 0;
  color: #ff6a2a;
  background: #fff4ed;
}

.place-address {
  margin-top: 6rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.row-arrow {
  color: #9aa8ba;
  font-size: 40rpx;
  font-weight: 500;
}

.frequent-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 18rpx;
}

.frequent-card {
  display: flex;
  gap: 14rpx;
  min-width: 0;
  padding: 20rpx;
  border: 2rpx solid transparent;
  border-radius: 24rpx;
}

.frequent-icon {
  width: 54rpx;
  height: 54rpx;
  border-radius: 18rpx;
  flex: 0 0 54rpx;
  font-size: 24rpx;
}

.frequent-main {
  min-width: 0;
}

.frequent-title,
.frequent-name,
.frequent-address {
  display: block;
  min-width: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.frequent-title {
  color: #159cff;
  font-size: 22rpx;
  font-weight: 900;
}

.frequent-name {
  margin-top: 6rpx;
  color: #111827;
  font-size: 26rpx;
  font-weight: 900;
}

.frequent-address {
  margin-top: 4rpx;
  font-size: 22rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: grid;
  grid-template-columns: 188rpx minmax(0, 1fr);
  align-items: center;
  gap: 18rpx;
  padding: 18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -10rpx 28rpx rgba(15, 23, 42, 0.08);
  box-sizing: border-box;
}

.bottom-text {
  color: #159cff;
  font-size: 27rpx;
  font-weight: 900;
  text-align: center;
}

.confirm-button {
  height: 82rpx;
  border-radius: 41rpx;
  color: #ffffff;
  background: #159cff;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 82rpx;
  box-shadow: 0 12rpx 24rpx rgba(21, 156, 255, 0.22);
}
