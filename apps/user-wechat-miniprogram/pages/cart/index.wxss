.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 148rpx;
  box-sizing: border-box;
  background: #f3f4f6;
}

.shop-card,
.cart-item,
.summary {
  margin-bottom: 18rpx;
  padding: 24rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 16rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.shop-name,
.item-name,
.payable {
  display: block;
  color: #111827;
  font-weight: 700;
}

.shop-name {
  font-size: 32rpx;
}

.shop-note,
.item-meta,
.bottom-note {
  display: block;
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.5;
}

.cart-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.check-dot {
  width: 34rpx;
  height: 34rpx;
  border: 2rpx solid #cbd5e1;
  border-radius: 50%;
}

.check-dot.checked {
  border-color: #009bf5;
  background: #009bf5;
}

.item-main {
  min-width: 0;
  flex: 1;
}

.item-name {
  font-size: 28rpx;
}

.price,
.payable {
  color: #009bf5;
}

.price {
  font-size: 28rpx;
  font-weight: 700;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0;
  color: #374151;
  font-size: 26rpx;
}

.bottom-bar {
  position: fixed;
  right: 28rpx;
  bottom: 32rpx;
  left: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  background: #111827;
  box-sizing: border-box;
}

.payable {
  color: #ffffff;
  font-size: 34rpx;
}

.bottom-note {
  color: #d1d5db;
}

.checkout-button {
  min-width: 176rpx;
  border-radius: 10rpx;
  color: #ffffff;
  background: #009bf5;
  font-size: 26rpx;
}
