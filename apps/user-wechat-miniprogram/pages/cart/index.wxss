.page {
  min-height: 100vh;
  padding: 0;
  box-sizing: border-box;
  background: #f3f4f6;
  overflow: hidden;
}

.mock-shop {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
}

.mock-hero,
.mock-row {
  border-radius: 18rpx;
  background: #ffffff;
  opacity: 0.8;
}

.mock-hero {
  height: 320rpx;
}

.mock-row {
  height: 140rpx;
  margin-top: 24rpx;
}

.mock-row.short {
  width: 72%;
}

.mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.54);
}

.drawer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 2;
  max-height: 72vh;
  padding: 28rpx 28rpx calc(24rpx + env(safe-area-inset-bottom));
  border-radius: 28rpx 28rpx 0 0;
  background: #ffffff;
  box-sizing: border-box;
}

.drawer-head {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.drawer-title,
.item-name,
.payable {
  display: block;
  color: #111827;
  font-weight: 700;
}

.drawer-title {
  font-size: 32rpx;
}

.shop-note,
.item-meta,
.bottom-note {
  display: block;
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.5;
}

.drawer-actions {
  display: flex;
  gap: 20rpx;
  color: #009bf5;
  font-size: 24rpx;
  font-weight: 700;
}

.empty-state {
  padding: 36rpx 0 28rpx;
  text-align: center;
}

.empty-title,
.empty-copy {
  display: block;
}

.empty-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 800;
}

.empty-copy {
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.6;
}

.cart-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #eef2f7;
}

.check-dot {
  width: 34rpx;
  height: 34rpx;
  border: 2rpx solid #cbd5e1;
  border-radius: 50%;
}

.check-dot.checked {
  border-color: #009bf5;
  background: #009bf5;
}

.thumb {
  width: 112rpx;
  height: 112rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #ffedd5, #fed7aa);
  color: #c2410c;
  text-align: center;
  line-height: 112rpx;
  font-weight: 900;
  overflow: hidden;
  flex: 0 0 112rpx;
}

.thumb-image {
  width: 100%;
  height: 100%;
}

.item-main {
  min-width: 0;
  flex: 1;
}

.item-name {
  font-size: 28rpx;
}

.price,
.payable {
  color: #009bf5;
}

.price {
  font-size: 28rpx;
  font-weight: 700;
}

.item-side {
  text-align: right;
}

.stepper {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 10rpx;
  color: #111827;
  font-size: 24rpx;
  font-weight: 700;
}

.stepper-button {
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  background: #eef2f7;
  text-align: center;
  line-height: 44rpx;
}

.stepper-button.primary {
  color: #ffffff;
  background: #009bf5;
}

.discount-note {
  display: block;
  margin-top: 18rpx;
  color: #f97316;
  font-size: 24rpx;
}

.bottom-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #eef2f7;
  box-sizing: border-box;
}

.all-check {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #374151;
  font-size: 24rpx;
}

.amount-wrap {
  flex: 1;
  min-width: 0;
  text-align: right;
}

.payable {
  color: #111827;
  font-size: 34rpx;
}

.checkout-button {
  min-width: 176rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: #009bf5;
  font-size: 26rpx;
}
