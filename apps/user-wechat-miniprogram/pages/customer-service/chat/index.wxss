.service-chat-page {
  min-height: 100vh;
  padding: 0 28rpx 210rpx;
  background: #f3f6f9;
  box-sizing: border-box;
}

.blue-nav {
  display: grid;
  grid-template-columns: 72rpx 1fr 120rpx;
  align-items: center;
  margin: 0 -28rpx;
  padding: calc(env(safe-area-inset-top) + 18rpx) 28rpx 24rpx;
  color: #ffffff;
  background: linear-gradient(90deg, #007aff, #00a5ff);
}

.nav-back {
  color: #ffffff;
  font-size: 58rpx;
  line-height: 52rpx;
}

.nav-title {
  font-size: 38rpx;
  font-weight: 900;
  text-align: center;
}

.nav-action {
  font-size: 28rpx;
  text-align: right;
}

.service-card,
.scene-tabs,
.order-card,
.suggest-card,
.human-row {
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.05);
}

.service-card {
  display: grid;
  grid-template-columns: 100rpx 1fr;
  gap: 24rpx;
  align-items: center;
  margin-top: 28rpx;
  padding: 28rpx;
}

.service-icon,
.avatar {
  width: 78rpx;
  height: 78rpx;
  border-radius: 39rpx;
  color: #ffffff;
  background: #008cff;
  text-align: center;
  line-height: 78rpx;
  font-size: 38rpx;
  font-weight: 900;
}

.service-title {
  display: block;
  color: #111827;
  font-size: 34rpx;
  font-weight: 900;
}

.service-meta {
  display: block;
  margin-top: 8rpx;
  color: #667085;
  font-size: 26rpx;
}

.scene-tabs {
  white-space: nowrap;
  margin-top: 18rpx;
  padding: 14rpx 12rpx;
}

.scene-chip {
  display: inline-flex;
  height: 58rpx;
  align-items: center;
  justify-content: center;
  margin-right: 14rpx;
  padding: 0 26rpx;
  border-radius: 29rpx;
  color: #374151;
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  font-size: 27rpx;
}

.scene-chip.active {
  color: #ffffff;
  background: #007aff;
  border-color: #007aff;
  font-weight: 900;
}

.notice-row {
  margin-top: 18rpx;
  padding: 20rpx 26rpx;
  border-radius: 18rpx;
  color: #4b5563;
  background: #eaf4ff;
  font-size: 27rpx;
}

.risk-tip-card {
  margin-top: 16rpx;
  padding: 18rpx 24rpx;
  border-radius: 16rpx;
  color: #9a3412;
  background: #fff7ed;
  border: 1rpx solid #fed7aa;
  font-size: 25rpx;
  line-height: 1.5;
}

.order-card {
  display: grid;
  grid-template-columns: 118rpx 1fr 154rpx;
  gap: 20rpx;
  align-items: center;
  margin: 22rpx 40rpx 0;
  padding: 24rpx;
}

.food-thumb {
  width: 104rpx;
  height: 104rpx;
  border-radius: 14rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #8b5e34, #f59e0b);
  text-align: center;
  line-height: 104rpx;
  font-size: 34rpx;
  font-weight: 900;
}

.order-copy text {
  display: block;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.45;
}

.order-copy text:first-child {
  color: #111827;
  font-size: 31rpx;
  font-weight: 900;
}

.order-side {
  text-align: right;
}

.order-side text {
  display: block;
  color: #007aff;
  font-size: 27rpx;
}

.order-side text:first-child {
  color: #ff4d00;
  margin-bottom: 36rpx;
}

.chat-list {
  margin-top: 24rpx;
}

.message-row {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.message-row.right {
  flex-direction: row-reverse;
}

.bubble {
  max-width: 520rpx;
  border-radius: 18rpx;
  background: #ffffff;
  padding: 20rpx 24rpx;
  color: #111827;
  font-size: 30rpx;
  line-height: 1.55;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.05);
}

.right .bubble {
  color: #ffffff;
  background: #007aff;
}

.suggest-card {
  width: 510rpx;
  margin: 0 0 24rpx 92rpx;
  padding: 24rpx;
}

.suggest-title {
  display: block;
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
}

.suggest-card > text {
  display: block;
  margin-top: 10rpx;
  color: #374151;
  font-size: 27rpx;
  line-height: 1.45;
}

.suggest-actions {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 22rpx;
  margin-top: 20rpx;
}

.suggest-actions button,
.human-row button,
.quick-actions button {
  height: 58rpx;
  border-radius: 10rpx;
  color: #007aff;
  background: #ffffff;
  border: 1rpx solid #007aff;
  line-height: 58rpx;
  font-size: 27rpx;
  padding: 0;
}

.human-row {
  display: grid;
  grid-template-columns: 1fr 170rpx;
  align-items: center;
  width: 510rpx;
  margin-left: 92rpx;
  padding: 18rpx 24rpx;
}

.human-row text {
  color: #111827;
  font-size: 28rpx;
}

.quick-actions {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: 120rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 18rpx;
}

.quick-actions button {
  height: 62rpx;
  border-radius: 31rpx;
  color: #111827;
  border: none;
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.08);
}

.composer {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: 38rpx;
  display: grid;
  grid-template-columns: 58rpx 1fr 58rpx 108rpx;
  gap: 12rpx;
  align-items: center;
  padding: 12rpx;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 -8rpx 24rpx rgba(15, 23, 42, 0.08);
}

.composer input {
  height: 60rpx;
  border-radius: 30rpx;
  background: #f3f6f9;
  padding: 0 24rpx;
  color: #111827;
  font-size: 27rpx;
}

.composer button {
  height: 58rpx;
  border-radius: 29rpx;
  line-height: 58rpx;
  padding: 0;
}

.composer .plus,
.composer .voice {
  color: #111827;
  background: #ffffff;
  border: 2rpx solid #111827;
  font-size: 24rpx;
}

.composer .send {
  color: #ffffff;
  background: #007aff;
  font-size: 28rpx;
  font-weight: 900;
}

button::after {
  border: none;
}

.safe-tip {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 4rpx;
  color: #8a8f98;
  font-size: 23rpx;
  text-align: center;
}
