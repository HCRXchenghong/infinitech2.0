.page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
  background: #f3f4f6;
}

.tabs {
  display: flex;
  gap: 16rpx;
}

.tab {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  color: #007ccc;
  background: #e0f2fe;
  font-size: 26rpx;
  font-weight: 600;
}

.post {
  margin-top: 24rpx;
  padding: 28rpx;
  border: 1rpx solid #dbeafe;
  border-radius: 16rpx;
  background: #ffffff;
}

.post-title {
  display: block;
  color: #111827;
  font-size: 32rpx;
  font-weight: 700;
}

.post-content {
  display: block;
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 26rpx;
  line-height: 1.5;
}
