<view class="page">
  <view class="plain-nav">
    <view class="nav-back" bindtap="handleBack">‹</view>
    <text class="nav-title">圈子</text>
    <text class="nav-action" bindtap="handlePublishTap">发布</text>
  </view>
  <view class="tabs">
    <text wx:for="{{tabs}}" wx:key="key" class="tab {{activeTab === item.key ? 'active' : ''}}" data-key="{{item.key}}" bindtap="handleTabTap">{{item.title}}</text>
  </view>

  <view class="publish-card">
    <text class="publish-placeholder">今天想分享什么？</text>
    <button class="publish-button" bindtap="handlePublishTap">发布</button>
  </view>

  <view wx:for="{{posts}}" wx:key="id" class="post">
    <view class="post-head">
      <view class="avatar">{{item.initial}}</view>
      <view class="post-main">
        <text class="author">{{item.author}}</text>
        <text class="tag">{{item.tag}}</text>
      </view>
    </view>
    <text class="post-title">{{item.title}}</text>
    <text class="post-content">{{item.content}}</text>
    <view class="post-actions">
      <text>评论</text>
      <text>点赞</text>
      <text>{{item.meta}}</text>
    </view>
  </view>

  <button class="float-button" bindtap="handlePublishTap">+</button>

</view>
