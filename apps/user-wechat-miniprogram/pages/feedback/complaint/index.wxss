.feedback-page {
  min-height: 100vh;
  padding: 0 28rpx 150rpx;
  background: #f3f6f9;
  box-sizing: border-box;
}

.blue-nav {
  display: grid;
  grid-template-columns: 72rpx 1fr 120rpx;
  align-items: center;
  margin: 0 -28rpx;
  padding: calc(env(safe-area-inset-top) + 18rpx) 28rpx 24rpx;
  color: #ffffff;
  background: linear-gradient(90deg, #007aff, #00a5ff);
}

.nav-back {
  color: #ffffff;
  font-size: 58rpx;
  line-height: 52rpx;
}

.nav-title {
  font-size: 38rpx;
  font-weight: 900;
  text-align: center;
}

.nav-action {
  font-size: 28rpx;
  text-align: right;
}

.intro-card,
.card,
.guard-card {
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.05);
}

.intro-card {
  display: grid;
  grid-template-columns: 96rpx 1fr;
  gap: 22rpx;
  align-items: center;
  margin-top: 28rpx;
  padding: 30rpx;
}

.intro-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 38rpx;
  color: #ffffff;
  background: #007aff;
  text-align: center;
  line-height: 76rpx;
  font-size: 42rpx;
  font-weight: 900;
}

.intro-title,
.section-title {
  display: block;
  color: #111827;
  font-size: 34rpx;
  font-weight: 900;
}

.intro-meta,
.intro-time {
  display: block;
  margin-top: 8rpx;
  color: #667085;
  font-size: 26rpx;
}

.intro-time {
  color: #ff4d00;
}

.card {
  margin-top: 18rpx;
  padding: 26rpx;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 20rpx;
}

.chip {
  min-width: 150rpx;
  height: 60rpx;
  border-radius: 30rpx;
  color: #374151;
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  text-align: center;
  line-height: 60rpx;
  font-size: 28rpx;
}

.chip.active {
  color: #ffffff;
  background: #007aff;
  border-color: #007aff;
  font-weight: 900;
}

.order-row {
  display: grid;
  grid-template-columns: 124rpx 1fr 132rpx;
  gap: 20rpx;
  align-items: center;
  margin-top: 18rpx;
}

.food-thumb {
  width: 110rpx;
  height: 110rpx;
  border-radius: 14rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #8b5e34, #f59e0b);
  text-align: center;
  line-height: 110rpx;
  font-weight: 900;
}

.order-row text {
  display: block;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.45;
}

.order-row text:first-child {
  color: #111827;
  font-size: 31rpx;
  font-weight: 900;
}

.order-row > view:last-child {
  color: #007aff;
  font-size: 27rpx;
  text-align: right;
}

textarea {
  width: 100%;
  min-height: 170rpx;
  margin-top: 18rpx;
  border: 1rpx solid #d8dde6;
  border-radius: 12rpx;
  padding: 22rpx;
  color: #111827;
  font-size: 28rpx;
  line-height: 1.5;
  box-sizing: border-box;
}

.severity-row {
  display: grid;
  grid-template-columns: 150rpx 1fr;
  align-items: center;
  gap: 18rpx;
  margin-top: 20rpx;
}

.severity-row > text {
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
}

.severity-row view {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.severity-row button {
  height: 58rpx;
  border-radius: 29rpx;
  color: #374151;
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  line-height: 58rpx;
  font-size: 27rpx;
  padding: 0;
}

.severity-row button.active {
  color: #ffffff;
  background: #007aff;
  border-color: #007aff;
}

.contact-row {
  display: grid;
  grid-template-columns: 140rpx 1fr 110rpx;
  gap: 16rpx;
  align-items: center;
  min-height: 78rpx;
  border-bottom: 1rpx solid #edf1f5;
  color: #667085;
  font-size: 28rpx;
}

.contact-row:last-child {
  border-bottom: none;
}

.contact-row input,
.contact-row text:nth-child(2) {
  color: #374151;
  text-align: right;
  font-size: 28rpx;
}

.contact-row text:last-child {
  color: #007aff;
  text-align: right;
}

.evidence-row {
  display: flex;
  gap: 24rpx;
  margin-top: 20rpx;
}

.evidence-row view {
  width: 150rpx;
  height: 130rpx;
  border-radius: 14rpx;
  color: #98a2b3;
  background: #eef1f5;
  text-align: center;
  line-height: 130rpx;
  font-size: 25rpx;
}

.evidence-row view:last-child {
  color: #007aff;
  background: #ffffff;
  border: 1rpx dashed #98a2b3;
}

.guard-card {
  margin-top: 18rpx;
  padding: 20rpx 26rpx;
}

.guard-card text {
  display: block;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.6;
}

.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  padding: 20rpx 28rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -10rpx 30rpx rgba(15, 23, 42, 0.08);
}

.bottom-actions button {
  height: 82rpx;
  border-radius: 14rpx;
  color: #ffffff;
  background: #007aff;
  line-height: 82rpx;
  font-size: 32rpx;
  font-weight: 900;
  padding: 0;
}

.bottom-actions button.ghost {
  color: #007aff;
  background: #ffffff;
  border: 1rpx solid #007aff;
}

button::after {
  border: none;
}
