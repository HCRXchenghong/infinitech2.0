.detail-page {
  min-height: 100vh;
  padding: 28rpx 28rpx 150rpx;
  background: #f3f6f9;
  box-sizing: border-box;
}

.plain-nav {
  display: grid;
  grid-template-columns: 72rpx 1fr 120rpx;
  align-items: center;
  padding: calc(env(safe-area-inset-top) + 20rpx) 0 26rpx;
}

.nav-back {
  color: #111827;
  font-size: 56rpx;
  line-height: 50rpx;
}

.nav-title {
  color: #111827;
  font-size: 36rpx;
  font-weight: 900;
  text-align: center;
}

.nav-action {
  color: #007aff;
  font-size: 24rpx;
  text-align: right;
}

.status-card,
.map-card,
.rider-card,
.detail-card,
.mini-card {
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.05);
}

.status-card {
  display: grid;
  grid-template-columns: 88rpx 1fr 168rpx;
  gap: 20rpx;
  align-items: center;
  padding: 30rpx;
}

.status-icon {
  width: 74rpx;
  height: 74rpx;
  border-radius: 37rpx;
  color: #ffffff;
  background: #007aff;
  text-align: center;
  line-height: 74rpx;
  font-size: 32rpx;
  font-weight: 900;
  overflow: hidden;
}

.status-image {
  display: block;
  width: 74rpx;
  height: 74rpx;
}

.status-title {
  display: block;
  color: #111827;
  font-size: 38rpx;
  font-weight: 900;
}

.status-subtitle,
.estimate {
  display: block;
  margin-top: 8rpx;
  color: #667085;
  font-size: 26rpx;
}

.estimate {
  color: #111827;
}

.estimate text,
.rating {
  color: #007aff;
}

.service-badge {
  align-self: flex-start;
  height: 44rpx;
  border-radius: 22rpx;
  color: #007aff;
  background: #eef6ff;
  line-height: 44rpx;
  text-align: center;
  font-size: 24rpx;
}

.map-card {
  margin-top: 22rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, #eef6ff, #ffffff);
}

.map-status {
  display: block;
  color: #0b57c2;
  font-size: 28rpx;
  font-weight: 900;
}

.map-line {
  display: grid;
  grid-template-columns: 64rpx 1fr 64rpx 1fr 64rpx;
  align-items: center;
  margin: 34rpx 12rpx 20rpx;
}

.map-pin,
.rider-dot {
  width: 58rpx;
  height: 58rpx;
  border-radius: 29rpx;
  color: #ffffff;
  text-align: center;
  line-height: 58rpx;
  font-weight: 900;
}

.pickup {
  background: #007aff;
}

.delivery {
  background: #ff7a00;
}

.rider-dot {
  background: #1d4ed8;
}

.dash {
  height: 0;
  border-top: 4rpx dashed #007aff;
}

.address-row {
  display: flex;
  justify-content: space-between;
  color: #374151;
  font-size: 25rpx;
}

.rider-card {
  display: grid;
  grid-template-columns: 78rpx 1fr 84rpx 84rpx;
  gap: 18rpx;
  align-items: center;
  margin-top: 22rpx;
  padding: 24rpx;
}

.rider-avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 35rpx;
  color: #ffffff;
  background: #007aff;
  text-align: center;
  line-height: 70rpx;
  font-weight: 900;
}

.rider-name,
.rider-subtitle {
  display: block;
}

.rider-name {
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
}

.rider-subtitle {
  margin-top: 8rpx;
  color: #667085;
  font-size: 25rpx;
}

.rider-action {
  height: 62rpx;
  border-radius: 31rpx;
  color: #007aff;
  background: #eef6ff;
  text-align: center;
  line-height: 62rpx;
  font-size: 24rpx;
}

.detail-card,
.mini-card {
  margin-top: 22rpx;
  padding: 28rpx;
}

.card-title {
  display: block;
  color: #111827;
  font-size: 32rpx;
  font-weight: 900;
  margin-bottom: 18rpx;
}

.timeline-row {
  display: grid;
  grid-template-columns: 42rpx 1fr auto;
  gap: 16rpx;
  min-height: 82rpx;
  color: #667085;
}

.timeline-dot {
  width: 24rpx;
  height: 24rpx;
  margin: 6rpx auto 0;
  border-radius: 12rpx;
  background: #cbd5e1;
}

.timeline-row.done .timeline-dot,
.timeline-row.active .timeline-dot {
  background: #007aff;
}

.timeline-row.active .timeline-title,
.timeline-row.active .timeline-time {
  color: #007aff;
}

.timeline-title {
  display: block;
  color: #111827;
  font-size: 28rpx;
}

.timeline-subtitle {
  display: block;
  margin-top: 6rpx;
  color: #667085;
  font-size: 24rpx;
}

.timeline-time {
  color: #667085;
  font-size: 24rpx;
}

.info-row {
  display: grid;
  grid-template-columns: 42rpx 146rpx 1fr;
  gap: 16rpx;
  align-items: center;
  min-height: 78rpx;
  border-bottom: 1rpx solid #edf1f5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-icon {
  width: 36rpx;
  height: 36rpx;
  border-radius: 10rpx;
  color: #ffffff;
  background: #007aff;
  text-align: center;
  line-height: 36rpx;
  font-size: 22rpx;
}

.info-title {
  color: #667085;
  font-size: 26rpx;
}

.info-value {
  color: #111827;
  font-size: 26rpx;
  text-align: right;
}

.two-col {
  display: grid;
  grid-template-columns: 1fr 1.25fr;
  gap: 18rpx;
}

.fee-row {
  display: flex;
  justify-content: space-between;
  margin-top: 14rpx;
  color: #4b5563;
  font-size: 25rpx;
}

.fee-row .strong {
  color: #007aff;
  font-size: 38rpx;
  font-weight: 900;
}

.tip-row {
  display: grid;
  grid-template-columns: 38rpx 1fr;
  gap: 10rpx;
  margin-top: 14rpx;
  color: #4b5563;
  font-size: 24rpx;
  line-height: 1.4;
}

.tip-row text:first-child {
  color: #007aff;
  font-weight: 900;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  display: grid;
  grid-template-columns: 1fr 1fr 1.55fr;
  gap: 18rpx;
  padding: 18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -8rpx 22rpx rgba(15, 23, 42, 0.08);
}

.ghost-button,
.primary-button {
  height: 72rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 72rpx;
}

.ghost-button {
  color: #007aff;
  background: #ffffff;
  border: 2rpx solid #007aff;
}

.primary-button {
  color: #ffffff;
  background: #007aff;
}

.ghost-button::after,
.primary-button::after {
  border: none;
}
