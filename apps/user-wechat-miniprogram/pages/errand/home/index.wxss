.errand-page {
  min-height: 100vh;
  padding: 28rpx 28rpx 150rpx;
  background: #f3f6f9;
  box-sizing: border-box;
}

.plain-nav {
  display: grid;
  grid-template-columns: 72rpx 1fr 120rpx;
  align-items: center;
  padding: calc(env(safe-area-inset-top) + 20rpx) 0 26rpx;
}

.nav-back {
  color: #111827;
  font-size: 56rpx;
  line-height: 50rpx;
}

.nav-title {
  color: #111827;
  font-size: 36rpx;
  font-weight: 900;
  text-align: center;
}

.nav-action {
  color: #007aff;
  font-size: 24rpx;
  text-align: right;
}

.hero-card,
.service-card,
.errand-card,
.tip-card {
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.05);
}

.hero-card {
  display: grid;
  grid-template-columns: 1fr 170rpx;
  gap: 20rpx;
  align-items: center;
  padding: 30rpx;
}

.hero-title,
.card-title {
  display: block;
  color: #111827;
  font-size: 34rpx;
  font-weight: 900;
}

.hero-subtitle {
  display: block;
  margin-top: 18rpx;
  color: #667085;
  font-size: 27rpx;
  line-height: 1.45;
}

.hero-art {
  width: 148rpx;
  height: 116rpx;
  border-radius: 28rpx;
  color: #007aff;
  background: #eaf4ff;
  text-align: center;
  line-height: 116rpx;
  font-size: 50rpx;
  font-weight: 900;
}

.hero-image {
  width: 170rpx;
  height: 132rpx;
  border-radius: 24rpx;
  box-shadow: 0 12rpx 24rpx rgba(0, 122, 255, 0.14);
}

.service-card {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  margin-top: 22rpx;
  overflow: hidden;
}

.service-item {
  min-height: 138rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 12rpx;
  align-items: center;
  color: #111827;
  font-size: 28rpx;
  font-weight: 800;
  border-right: 1rpx solid #edf1f5;
}

.service-item:last-child {
  border-right: none;
}

.service-item.active {
  color: #007aff;
  box-shadow: inset 0 0 0 3rpx #007aff;
}

.service-icon {
  color: #007aff;
  font-size: 42rpx;
  font-weight: 900;
}

.errand-card {
  margin-top: 22rpx;
  padding: 28rpx;
}

.info-row,
.detail-row,
.coupon-row {
  display: grid;
  align-items: center;
  gap: 18rpx;
  min-height: 82rpx;
  border-bottom: 1rpx solid #edf1f5;
  color: #111827;
  font-size: 28rpx;
}

.info-row {
  grid-template-columns: 42rpx 150rpx 1fr;
}

.detail-row {
  grid-template-columns: 150rpx 1fr 24rpx;
}

.info-row:last-child,
.detail-row:last-child {
  border-bottom: none;
}

.mark {
  width: 38rpx;
  height: 38rpx;
  border-radius: 10rpx;
  color: #ffffff;
  text-align: center;
  line-height: 38rpx;
  font-size: 24rpx;
}

.pickup,
.person {
  background: #007aff;
}

.delivery {
  background: #ff7a00;
}

.info-row text:last-child,
.detail-row text:nth-child(2),
.detail-row input {
  color: #374151;
  text-align: right;
}

.detail-row input {
  font-size: 28rpx;
}

.item-type-row {
  display: grid;
  grid-template-columns: 150rpx 1fr;
  align-items: center;
  margin-top: 24rpx;
  padding-bottom: 22rpx;
  border-bottom: 1rpx solid #edf1f5;
  color: #111827;
  font-size: 28rpx;
}

.item-preview {
  display: grid;
  grid-template-columns: 118rpx 1fr;
  gap: 18rpx;
  align-items: center;
  margin-top: 20rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: #f8fbff;
  border: 1rpx solid #e3efff;
}

.item-image {
  width: 104rpx;
  height: 104rpx;
  border-radius: 14rpx;
}

.item-preview text {
  display: block;
}

.item-preview text:first-child {
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
}

.item-preview text:last-child {
  margin-top: 8rpx;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.35;
}

.type-chips {
  display: flex;
  gap: 14rpx;
  justify-content: flex-end;
}

.type-chip {
  min-width: 92rpx;
  height: 50rpx;
  padding: 0 18rpx;
  border-radius: 25rpx;
  color: #374151;
  background: #eef1f5;
  line-height: 50rpx;
  text-align: center;
}

.type-chip.active {
  color: #ffffff;
  background: #007aff;
}

.fee-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  margin-top: 28rpx;
  text-align: center;
}

.fee-grid view {
  border-right: 1rpx solid #edf1f5;
}

.fee-grid view:last-child {
  border-right: none;
}

.fee-grid text {
  display: block;
  color: #667085;
  font-size: 24rpx;
}

.fee-grid text:last-child {
  margin-top: 10rpx;
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
}

.fee-grid view:last-child text:last-child {
  color: #007aff;
  font-size: 42rpx;
}

.coupon-row {
  grid-template-columns: 44rpx 1fr auto;
  margin-top: 24rpx;
  border-bottom: none;
}

.coupon-row text:first-child {
  color: #ff7a00;
  font-weight: 900;
}

.coupon-row text:last-child {
  color: #ff4d00;
}

.tip-card {
  margin-top: 22rpx;
  padding: 24rpx 28rpx;
}

.tip-card view {
  display: grid;
  grid-template-columns: 38rpx 1fr;
  gap: 12rpx;
  align-items: center;
  margin-top: 12rpx;
  color: #4b5563;
  font-size: 26rpx;
}

.tip-card view:first-child {
  margin-top: 0;
}

.tip-card text:first-child {
  color: #007aff;
  font-weight: 900;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  display: grid;
  grid-template-columns: 1fr 1.35fr;
  gap: 18rpx;
  padding: 18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -8rpx 22rpx rgba(15, 23, 42, 0.08);
}

.service-button,
.submit-button {
  height: 78rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 78rpx;
}

.service-button {
  color: #007aff;
  background: #ffffff;
  border: 2rpx solid #007aff;
}

.submit-button {
  color: #ffffff;
  background: #007aff;
}

.service-button::after,
.submit-button::after {
  border: none;
}
