<view class="red-send-page">
  <view class="plain-nav">
    <view class="nav-back" bindtap="handleBack">‹</view>
    <text class="nav-title">发红包</text>
    <text class="nav-action" bindtap="handleRecords">红包记录</text>
  </view>

  <view class="red-hero">
    <view class="envelope">福</view>
    <view class="hero-copy">
      <text>发给 蓝海餐厅商户群</text>
      <text>326 人群聊</text>
    </view>
    <view class="segmented">
      <view class="segment {{type === 'random' ? 'active' : ''}}" data-type="random" bindtap="handleTypeTap">拼手气红包</view>
      <view class="segment {{type === 'fixed' ? 'active' : ''}}" data-type="fixed" bindtap="handleTypeTap">普通红包</view>
    </view>
    <text class="hero-tip">每个红包随机金额</text>
  </view>

  <view class="form-card">
    <view class="form-row">
      <text>红包个数</text>
      <input type="number" value="{{count}}" bindinput="handleCountInput" />
      <text>个</text>
      <text class="muted">本群共 326 人</text>
    </view>
    <view class="form-row">
      <text>总金额</text>
      <input type="digit" value="{{amount}}" bindinput="handleAmountInput" />
      <text>元</text>
      <text class="muted">人均约 {{averageText}}</text>
    </view>
    <view class="form-row">
      <text>祝福语</text>
      <input value="{{message}}" bindinput="handleMessageInput" />
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="amount-block">
    <text>红包总金额</text>
    <view><text>¥</text><text>{{totalText}}</text></view>
  </view>

  <button class="pay-button" loading="{{submitting}}" disabled="{{submitting}}" bindtap="handleSubmit">塞钱进红包</button>
  <text class="pay-tip">点击后选择支付方式并验证支付密码</text>
  <text class="risk-tip">未领完 24 小时后退回余额 · 异常领取会触发风控校验</text>
</view>
