@import "../login/index.wxss";

.auth-page.register .auth-spacer {
  height: calc(env(safe-area-inset-top) + 70px);
}

.auth-page.register .auth-brand {
  margin-bottom: 24px;
}

.auth-page.register .auth-primary {
  margin-top: 18px;
}

.auth-page.register .auth-divider {
  margin-top: 28px;
}

.auth-agreement {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 16px;
  color: #6b7280;
  font-size: 12px;
}

.auth-check {
  width: 14px;
  height: 14px;
  border-radius: 7px;
  border: 1px solid #cbd5e1;
  box-sizing: border-box;
}

.auth-check.checked {
  border: 4px solid #009bf5;
}
