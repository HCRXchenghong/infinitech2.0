<view class="auth-page">
  <view class="auth-spacer"></view>
  <view class="auth-brand">
    <text class="auth-title">悦享e食</text>
    <text class="auth-subtitle">附近美食，一键下单，准时送达</text>
  </view>

  <view class="auth-tabs">
    <view class="auth-tab {{mode === 'code' ? 'active' : ''}}" data-mode="code" bindtap="handleModeTap">验证码登录</view>
    <view class="auth-tab {{mode === 'password' ? 'active' : ''}}" data-mode="password" bindtap="handleModeTap">密码登录</view>
  </view>

  <view class="auth-form">
    <input class="auth-input" type="number" maxlength="11" placeholder="手机号" value="{{phone}}" bindinput="handlePhoneInput" />
    <block wx:if="{{mode === 'code'}}">
      <view class="auth-code-row">
        <input class="auth-input code" type="number" maxlength="6" placeholder="验证码" value="{{code}}" bindinput="handleCodeInput" />
        <button class="auth-code-button" size="mini" loading="{{codeSending}}" disabled="{{codeSending}}" bindtap="handleSendCode">获取验证码</button>
      </view>
      <text wx:if="{{codeStatusText}}" class="auth-code-status">{{codeStatusText}}</text>
    </block>
    <input wx:else class="auth-input" password placeholder="密码" value="{{password}}" bindinput="handlePasswordInput" />
    <button class="auth-primary" loading="{{submitting}}" disabled="{{submitting}}" bindtap="handleLogin">登录</button>
  </view>

  <view class="auth-footer">
    <text>还没有账号？ </text>
    <text class="auth-link" bindtap="goRegister">去注册</text>
  </view>
  <text class="auth-tip">登录后可同步订单、消息与优惠券</text>

  <view class="auth-divider">
    <view></view>
    <text>或</text>
    <view></view>
  </view>

  <button class="auth-wechat" loading="{{wechatLoading}}" disabled="{{wechatLoading}}" bindtap="handleWechatLogin">微信登录</button>
  <text wx:if="{{wechatStatusText}}" class="auth-wechat-status">{{wechatStatusText}}</text>
</view>
