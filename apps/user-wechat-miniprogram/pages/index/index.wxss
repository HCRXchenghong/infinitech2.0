.page {
  min-height: 100vh;
  padding: 0 28rpx 42rpx;
  box-sizing: border-box;
  background:
    linear-gradient(180deg, #eaf5ff 0, #eef8ff 300rpx, #f7fbff 520rpx, #f5f7fb 100%);
  color: #111827;
}

.home-sticky {
  position: sticky;
  top: 0;
  z-index: 40;
  margin: 0 -28rpx;
  padding: 88rpx 28rpx 24rpx;
  background: linear-gradient(180deg, #eaf5ff 0, #eef8ff 100%);
  box-shadow: 0 10rpx 24rpx rgba(52, 83, 125, 0.05);
  box-sizing: border-box;
}

.location-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 188rpx;
  align-items: center;
  gap: 18rpx;
}

.location-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.location-pin {
  position: relative;
  width: 34rpx;
  height: 42rpx;
  flex: 0 0 34rpx;
  border-radius: 20rpx 20rpx 20rpx 4rpx;
  background: linear-gradient(180deg, #119dff, #0077d9);
  box-shadow: 0 8rpx 16rpx rgba(0, 126, 220, 0.22);
  transform: rotate(-45deg);
}

.location-pin-core {
  position: absolute;
  left: 9rpx;
  top: 9rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 8rpx;
  background: #ffffff;
}

.location-pin::after {
  content: "";
  position: absolute;
  left: 17rpx;
  bottom: -10rpx;
  width: 24rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(0, 126, 220, 0.16);
  transform: rotate(45deg);
}

.location {
  display: block;
  max-width: 360rpx;
  color: #111827;
  font-size: 48rpx;
  font-weight: 900;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  letter-spacing: 0;
}

.location-arrow {
  color: #111827;
  font-size: 26rpx;
  font-weight: 900;
}

.system-capsule-gap {
  width: 188rpx;
  height: 64rpx;
}

.search-bar {
  height: 88rpx;
  margin-top: 22rpx;
  padding: 0 30rpx;
  border: 2rpx solid rgba(205, 217, 230, 0.92);
  border-radius: 44rpx;
  background: rgba(255, 255, 255, 0.96);
  display: flex;
  align-items: center;
  gap: 18rpx;
  box-sizing: border-box;
  box-shadow: 0 12rpx 34rpx rgba(15, 23, 42, 0.05);
}

.search-icon {
  color: #9aa8ba;
  font-size: 42rpx;
  line-height: 1;
}

.search-placeholder {
  min-width: 0;
  color: #8a96a6;
  font-size: 32rpx;
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.hero-carousel {
  position: relative;
  height: 304rpx;
  margin-top: 28rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #f7fbff, #ddecff);
  box-shadow: 0 16rpx 44rpx rgba(52, 83, 125, 0.1);
  overflow: hidden;
  box-sizing: border-box;
}

.hero-swiper {
  width: 100%;
  height: 304rpx;
}

.hero-slide {
  position: relative;
  width: 100%;
  height: 304rpx;
  padding: 48rpx 32rpx 36rpx;
  overflow: hidden;
  box-sizing: border-box;
}

.hero-copy {
  position: relative;
  z-index: 2;
  width: 382rpx;
}

.hero-brand {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.hero-logo {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  flex: 0 0 88rpx;
}

.hero-title {
  color: #111827;
  font-size: 56rpx;
  font-weight: 900;
  line-height: 1.05;
  letter-spacing: 0;
}

.hero-subtitle,
.hero-note {
  display: block;
  color: #111827;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.55;
}

.hero-subtitle {
  margin-top: 30rpx;
}

.hero-note {
  color: #516173;
  font-weight: 600;
  max-width: 360rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.hero-image {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 52%;
  height: 100%;
}

.hero-indicator {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 24rpx;
  display: flex;
  justify-content: center;
  gap: 10rpx;
  z-index: 5;
  pointer-events: none;
}

.hero-dot {
  width: 18rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(0, 155, 245, 0.22);
  transition: width 0.2s ease;
}

.hero-dot.active {
  width: 34rpx;
  background: #159cff;
}

.module-board {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 28rpx 14rpx;
  margin-top: 24rpx;
  padding: 30rpx 18rpx 26rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 14rpx 40rpx rgba(52, 83, 125, 0.08);
}

.module-item {
  min-width: 0;
  min-height: 142rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  gap: 12rpx;
}

.module-icon-wrap {
  width: 92rpx;
  height: 92rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.module-icon-image {
  display: block;
  width: 92rpx;
  height: 92rpx;
}

.module-glyph {
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1;
}

.module-label {
  display: block;
  max-width: 126rpx;
  color: #2d3746;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.2;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.tone-blue {
  background: linear-gradient(180deg, #34a8ff, #0e88f3);
}

.tone-orange {
  background: linear-gradient(180deg, #ffb74f, #ff8b1e);
}

.tone-green {
  background: linear-gradient(180deg, #7adf70, #3cc051);
}

.tone-sky {
  background: linear-gradient(180deg, #44b9ff, #1899f2);
}

.tone-purple {
  background: linear-gradient(180deg, #8c7cff, #6c62f3);
}

.tone-pink {
  background: linear-gradient(180deg, #ff9f9d, #ff7573);
}

.tone-red {
  background: linear-gradient(180deg, #ff7b7b, #ff4b4b);
}

.tone-gold {
  background: linear-gradient(180deg, #ffc44b, #f8a800);
}

.deal-section,
.takeout-section {
  margin-top: 24rpx;
  padding: 26rpx 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 14rpx 40rpx rgba(52, 83, 125, 0.07);
  box-sizing: border-box;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.section-title {
  color: #111827;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.25;
}

.section-more,
.section-note {
  color: #8793a5;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.section-arrow {
  font-size: 38rpx;
  line-height: 1;
}

.deal-scroll {
  width: 100%;
  white-space: nowrap;
}

.deal-strip {
  display: flex;
  gap: 18rpx;
  padding-bottom: 2rpx;
}

.deal-mini-card {
  flex: 0 0 252rpx;
  width: 252rpx;
  min-height: 324rpx;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 26rpx rgba(52, 83, 125, 0.08);
  overflow: hidden;
  box-sizing: border-box;
}

.deal-mini-image {
  display: block;
  width: 252rpx;
  height: 142rpx;
  background: #eef4fb;
}

.deal-mini-copy {
  padding: 14rpx 14rpx 16rpx;
  box-sizing: border-box;
}

.deal-mini-title {
  display: block;
  color: #111827;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 1.28;
  height: 64rpx;
  overflow: hidden;
}

.deal-mini-discount {
  display: inline-block;
  margin-top: 10rpx;
  padding: 5rpx 9rpx;
  border-radius: 8rpx;
  background: #ff4d4f;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 1;
}

.deal-mini-price-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-top: 10rpx;
}

.deal-mini-price {
  color: #ff4d2f;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1;
  white-space: nowrap;
}

.deal-mini-origin {
  color: #9aa6b6;
  font-size: 22rpx;
  text-decoration: line-through;
}

.deal-mini-sold {
  display: block;
  margin-top: 8rpx;
  color: #7b8796;
  font-size: 21rpx;
  font-weight: 600;
  line-height: 1.2;
}

.deal-more-card {
  flex: 0 0 142rpx;
  width: 142rpx;
  min-height: 324rpx;
  border: 2rpx solid rgba(21, 156, 255, 0.16);
  border-radius: 18rpx;
  background: linear-gradient(180deg, #f4faff, #ffffff);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  box-shadow: 0 10rpx 24rpx rgba(52, 83, 125, 0.06);
  box-sizing: border-box;
}

.deal-more-icon {
  width: 50rpx;
  height: 50rpx;
  border-radius: 25rpx;
  background: #159cff;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 50rpx;
  text-align: center;
}

.deal-more-title {
  color: #1f2a3a;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1;
}

.deal-more-subtitle {
  color: #8793a5;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 1;
}

.takeout-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.takeout-card {
  display: flex;
  align-items: stretch;
  gap: 18rpx;
  min-height: 176rpx;
  padding: 14rpx;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 26rpx rgba(52, 83, 125, 0.08);
  box-sizing: border-box;
}

.takeout-image {
  width: 186rpx;
  height: 148rpx;
  border-radius: 16rpx;
  background: #eef4fb;
  flex: 0 0 186rpx;
}

.takeout-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.takeout-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.takeout-title {
  min-width: 0;
  color: #111827;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 1.25;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.takeout-tag {
  flex: 0 0 auto;
  max-width: 142rpx;
  padding: 5rpx 8rpx;
  border-radius: 8rpx;
  background: #ff6a4d;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 1.1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.takeout-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #566376;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.25;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.takeout-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 10rpx;
}

.takeout-rating {
  color: #ff8a00;
  font-size: 22rpx;
  font-weight: 900;
  white-space: nowrap;
}

.takeout-sales {
  min-width: 0;
  color: #788496;
  font-size: 22rpx;
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.takeout-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-top: 10rpx;
  color: #788496;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
}

.takeout-delivery {
  min-width: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.takeout-price {
  flex: 0 0 auto;
  color: #ff4d2f;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1;
  text-align: center;
}
