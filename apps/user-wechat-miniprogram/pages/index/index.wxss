.page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.hero {
  padding: 40rpx 0 28rpx;
}

.logo {
  display: block;
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 16rpx;
  border-radius: 18rpx;
}

.title {
  display: block;
  color: #009bf5;
  font-size: 48rpx;
  font-weight: 700;
}

.subtitle {
  display: block;
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 26rpx;
}

.module-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.module {
  min-height: 128rpx;
  padding: 28rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 16rpx;
  background: #ffffff;
  box-sizing: border-box;
  font-size: 30rpx;
  font-weight: 600;
}

.module.primary {
  color: #ffffff;
  border-color: #009bf5;
  background: #009bf5;
}

.section {
  margin-top: 32rpx;
}

.section-title {
  display: block;
  margin-bottom: 16rpx;
  color: #111827;
  font-size: 30rpx;
  font-weight: 700;
}

.home-card,
.meal-match {
  margin-top: 16rpx;
  padding: 28rpx;
  border: 1rpx solid #dbeafe;
  border-radius: 16rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.card-title {
  display: block;
  color: #111827;
  font-size: 30rpx;
  font-weight: 700;
}

.card-subtitle {
  display: block;
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.5;
}
